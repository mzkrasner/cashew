#!/bin/bash
# dev - Project session manager with git worktree support
#
# Structure supported:
#   <projects-root>/<repo>/<worktree>/     - git worktrees
#   <projects-root>/<repo>/                - regular repos
#
# Session naming uses "_" separator (internal session names don't allow "/"):
#   repo_worktree_sub  maps to  repo/worktree/sub in commands
#
# Usage:
#   dev                              - List all projects and sessions
#   dev <repo>                       - Attach to repo's main/default session
#   dev <repo>/<worktree>            - Attach to a specific worktree session
#   dev <repo>/<worktree>/<sub>      - Attach to sub-session (prefer /pi for worktrees)
#   dev hub                          - Attach to hub session at projects root
#   dev hub/<sub>                    - Attach to hub sub-session (e.g., hub/claude)
#   dev new <repo> <url>             - Clone repo as bare + create main worktree
#   dev init <repo>                  - Create new local repo with worktree structure
#   dev wt <repo> <branch> [base]    - Add a worktree for a branch
#   dev task new <repo> <slug>       - Create task artifacts under .cashew/tasks
#   dev task status <repo> <slug>    - Show task status + artifacts
#   dev task open <repo> <slug> [role] - Open a persistent task role session
#   dev task slice new <repo> <slug> <slice-id> - Declare a commit slice
#   dev task slice status <repo> <slug> <slice-id> - Show slice lifecycle state
#   dev task slice validate <repo> <slug> <slice-id> - Validate one slice
#   dev task slice approve-commit <repo> <slug> <slice-id> - Allow this slice to be committed
#   dev task slice committed <repo> <slug> <slice-id> <commit> - Record committed slice
#   dev task lock-plan <repo> <slug> - Mark the plan locked
#   dev task start-impl <repo> <slug> [worktree] - Gate implementation on a locked plan
#   dev kill <session>               - Kill a specific session
#   dev kill-all                     - Kill all sessions

PROJECTS_DIR="${CASHEW_PROJECTS_DIR:-$HOME/projects}"
if [ -z "${CASHEW_PROJECTS_DIR:-}" ] && [ -d "$HOME/Projects" ]; then
    PROJECTS_DIR="$HOME/Projects"
fi
SEP="_"  # Session name separator (internal session names don't allow /)
TASK_ROOT_REL=".cashew/tasks"
TASK_SESSION_DIR_NAME="sessions"
TASK_SLICE_DIR_NAME="slices"

# Colors
BOLD='\033[1m'
DIM='\033[2m'
CYAN='\033[36m'
GREEN='\033[32m'
YELLOW='\033[33m'
MAGENTA='\033[35m'
RED='\033[31m'
RESET='\033[0m'

# Convert path-style (repo/wt/sub) to session name (repo_wt_sub)
to_session_name() {
    echo "$1" | sed "s|/|${SEP}|g"
}

# Convert session name back to path-style for display
to_display_name() {
    echo "$1" | sed "s|${SEP}|/|g"
}

task_safe() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's|[^a-z0-9._-]|-|g'
}

repo_base_dir() {
    local repo="$1"
    local repo_dir="$PROJECTS_DIR/$repo"
    if [ -d "$repo_dir/.bare" ]; then
        echo "$repo_dir/main"
    else
        echo "$repo_dir"
    fi
}

task_dir() {
    local repo="$1"
    local slug="$2"
    echo "$(repo_base_dir "$repo")/$TASK_ROOT_REL/$slug"
}

task_meta_file() {
    local repo="$1"
    local slug="$2"
    echo "$(task_dir "$repo" "$slug")/task.json"
}

task_session_dir() {
    local repo="$1"
    local slug="$2"
    local role="$3"
    echo "$(task_dir "$repo" "$slug")/$TASK_SESSION_DIR_NAME/$role"
}

task_session_path() {
    local repo="$1"
    local slug="$2"
    local role="$3"
    local worktree="${4:-}"

    if [ -n "$worktree" ]; then
        echo "$repo/$worktree/task-$slug-$role"
    else
        echo "$repo/main/task-$slug-$role"
    fi
}

task_target_dir() {
    local repo="$1"
    local slug="$2"
    local role="$3"
    local worktree_override="${4:-}"
    local repo_dir="$PROJECTS_DIR/$repo"
    local meta_file
    local worktree=""

    meta_file=$(task_meta_file "$repo" "$slug")
    if [ -n "$worktree_override" ]; then
        worktree="$worktree_override"
    elif [ -f "$meta_file" ]; then
        worktree=$(jq -r '.worktree // empty' "$meta_file" 2>/dev/null)
    fi

    case "$role" in
        implementer-codex|implementation-review-codex|implementation-critic-claude)
            if [ -z "$worktree" ]; then
                echo ""
                return
            fi
            if [ -d "$repo_dir/.bare" ]; then
                echo "$repo_dir/$worktree"
            else
                echo "$repo_dir"
            fi
            ;;
        *)
            echo "$(repo_base_dir "$repo")"
            ;;
    esac
}

task_slices_dir() {
    local repo="$1"
    local slug="$2"
    echo "$(task_dir "$repo" "$slug")/$TASK_SLICE_DIR_NAME"
}

task_slice_dir() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"
    echo "$(task_slices_dir "$repo" "$slug")/$slice_id"
}

task_slice_rounds_dir() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"
    echo "$(task_slice_dir "$repo" "$slug" "$slice_id")/rounds"
}

task_slice_round_name() {
    local round="${1:-1}"
    printf 'round-%02d' "$round"
}

task_slice_current_round() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"
    local meta_file
    meta_file=$(task_slice_meta_file "$repo" "$slug" "$slice_id")
    jq -r '.currentRound // 1' "$meta_file" 2>/dev/null
}

task_slice_round_dir() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"
    local round="${4:-}"
    if [ -z "$round" ]; then
        round=$(task_slice_current_round "$repo" "$slug" "$slice_id")
    fi
    echo "$(task_slice_rounds_dir "$repo" "$slug" "$slice_id")/$(task_slice_round_name "$round")"
}

task_slice_round_state_file() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"
    local round="${4:-}"
    echo "$(task_slice_round_dir "$repo" "$slug" "$slice_id" "$round")/state.json"
}

task_slice_meta_file() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"
    echo "$(task_slice_dir "$repo" "$slug" "$slice_id")/status.json"
}

task_slice_review_doc() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"
    local reviewer="$4"
    local dir
    dir=$(task_slice_round_dir "$repo" "$slug" "$slice_id")

    case "$reviewer" in
        codex)
            echo "$dir/review-codex.md"
            ;;
        claude)
            echo "$dir/review-claude.md"
            ;;
        *)
            echo ""
            ;;
    esac
}

task_review_state_file() {
    local repo="$1"
    local slug="$2"
    local phase="$3"
    local review_doc
    review_doc=$(task_review_doc "$repo" "$slug" "$phase")
    if [ -n "$review_doc" ]; then
        echo "${review_doc%.md}.state.json"
    else
        echo ""
    fi
}

task_slice_list() {
    local repo="$1"
    local slug="$2"
    local slices_dir
    slices_dir=$(task_slices_dir "$repo" "$slug")
    if [ ! -d "$slices_dir" ]; then
        return
    fi
    local path
    for path in "$slices_dir"/*; do
        [ -d "$path" ] || continue
        basename "$path"
    done | sort
}

task_slice_count() {
    local repo="$1"
    local slug="$2"
    local count=0
    local slice_id
    while IFS= read -r slice_id; do
        [ -n "$slice_id" ] || continue
        count=$((count + 1))
    done < <(task_slice_list "$repo" "$slug")
    echo "$count"
}

task_current_slice() {
    local repo="$1"
    local slug="$2"
    local slice_id
    while IFS= read -r slice_id; do
        [ -n "$slice_id" ] || continue
        local meta_file
        meta_file=$(task_slice_meta_file "$repo" "$slug" "$slice_id")
        local status
        status=$(jq -r '.status // "planned"' "$meta_file" 2>/dev/null)
        if [ "$status" != "committed" ]; then
            echo "$slice_id"
            return 0
        fi
    done < <(task_slice_list "$repo" "$slug")
    echo ""
}

task_require_current_slice() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"
    local current
    current=$(task_current_slice "$repo" "$slug")
    if [ -z "$current" ]; then
        echo "All slices are already committed for $repo/$slug"
        return 1
    fi
    if [ "$current" != "$slice_id" ]; then
        echo "Slice progression is sequential. Current active slice is $current, not $slice_id."
        return 1
    fi
    return 0
}

role_is_pi() {
    case "$1" in
        plan-owner-codex|plan-review-codex|implementer-codex|implementation-review-codex)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

role_default_command() {
    local role="$1"
    local session_dir="$2"

    local codex_provider="${CASHEW_CODEX_PROVIDER:-openai}"
    local codex_model="${CASHEW_CODEX_MODEL:-gpt-5.4}"
    local codex_thinking="${CASHEW_CODEX_THINKING:-high}"
    local claude_model="${CASHEW_CLAUDE_MODEL:-}"

    case "$role" in
        plan-owner-codex|plan-review-codex|implementer-codex|implementation-review-codex)
            printf 'pi --provider %q --model %q --thinking %q --session-dir %q' \
                "$codex_provider" "$codex_model" "$codex_thinking" "$session_dir"
            ;;
        plan-critic-claude|implementation-critic-claude)
            if [ -z "$claude_model" ]; then
                echo "CASHEW_CLAUDE_MODEL is required for Claude task roles: $role" >&2
                return 1
            fi
            printf 'claude --dangerously-skip-permissions --model %q' "$claude_model"
            ;;
        *)
            return 1
            ;;
    esac
}

task_set_json() {
    local meta_file="$1"
    local jq_expr="$2"
    local tmp
    tmp=$(mktemp)
    jq "$jq_expr" "$meta_file" > "$tmp" && mv "$tmp" "$meta_file"
}

task_file_has_meaningful_content() {
    local file="$1"
    if [ ! -f "$file" ]; then
        return 1
    fi

    local stripped
    stripped=$(
        sed -E '/^[[:space:]]*#/d' "$file" | \
        sed -E '/^[[:space:]]*$/d' | \
        sed -E '/^[[:space:]]*Track open blockers and their resolution here\.[[:space:]]*$/d' | \
        sed -E '/^[[:space:]]*Document the target repo.*before implementation\.[[:space:]]*$/d' | \
        sed -E '/^[[:space:]]*Add fenced bash\/sh commands for the checks that must pass before this slice may be committed\.[[:space:]]*$/d' | \
        sed -E '/^[[:space:]]*(Goal|Why|Constraints|Open Questions|Non-Goals|Affected Files \/ Systems|Risks|Acceptance Criteria|Tests|Rollout \/ Rollback|Blocking Issues|Non-Blocking Concerns|Sign-off|Architecture \/ Risk Issues|Commit Slices|Commit Boundary|Scope \/ Files|Verification|Summary|Reviewer Findings Verification|Additional Context)[[:space:]]*$/d'
    )

    [ -n "$stripped" ]
}

task_has_open_checkboxes() {
    local file="$1"
    [ -f "$file" ] && grep -Eq '^[[:space:]]*[-*][[:space:]]+\[[[:space:]]\]' "$file"
}

task_hash_file() {
    local file="$1"
    if [ ! -f "$file" ]; then
        echo ""
        return
    fi
    shasum -a 256 "$file" | awk '{print $1}'
}

task_section_body() {
    local file="$1"
    local heading="$2"
    awk -v heading="## $heading" '
        $0 == heading { in_section = 1; next }
        in_section && /^## / { exit }
        in_section { print }
    ' "$file"
}

task_section_has_meaningful_content() {
    local file="$1"
    local heading="$2"
    local body
    body=$(task_section_body "$file" "$heading" | \
        sed -E '/^[[:space:]]*$/d' | \
        sed -E '/^[[:space:]]*[-*]?[[:space:]]*(none|n\/a|no blocking issues|no architecture issues|no issues)[[:space:]]*$/Id')
    [ -n "$body" ]
}

task_review_decision_line() {
    local file="$1"
    if [ ! -f "$file" ]; then
        echo "missing"
        return
    fi

    local decision
    decision=$(awk -F':' '/^Decision:/ {gsub(/^[ \t]+|[ \t]+$/, "", $2); print toupper($2); exit}' "$file")
    if [ -z "$decision" ]; then
        echo "missing"
        return
    fi

    case "$decision" in
        APPROVED)
            echo "approved"
            ;;
        BLOCKED)
            echo "blocked"
            ;;
        PENDING)
            echo "pending"
            ;;
        *)
            echo "invalid"
            ;;
    esac
}

task_review_doc() {
    local repo="$1"
    local slug="$2"
    local phase="$3"
    local dir
    dir=$(task_dir "$repo" "$slug")

    case "$phase" in
        plan-codex)
            echo "$dir/plan-review-codex.md"
            ;;
        plan-claude)
            echo "$dir/plan-review-claude.md"
            ;;
        implementation-codex)
            echo "$dir/implementation-review-codex.md"
            ;;
        implementation-claude)
            echo "$dir/implementation-review-claude.md"
            ;;
        *)
            echo ""
            ;;
    esac
}

task_infer_review_decision() {
    local file="$1"
    local blockers_heading="$2"
    local decision_state

    if [ ! -f "$file" ]; then
        echo "missing"
        return
    fi

    decision_state=$(task_review_decision_line "$file")
    if [ "$decision_state" = "invalid" ]; then
        echo "invalid"
        return
    fi

    if task_section_has_meaningful_content "$file" "$blockers_heading"; then
        echo "blocked"
        return
    fi

    if [ "$decision_state" = "approved" ]; then
        echo "approved"
        return
    fi

    echo "$decision_state"
}

task_structured_review_decision() {
    local file="$1"
    if [ ! -f "$file" ]; then
        echo "missing"
        return
    fi
    jq -r '.decision // "missing"' "$file" 2>/dev/null | tr '[:upper:]' '[:lower:]'
}

task_structured_review_findings_invalid_count() {
    local file="$1"
    if [ ! -f "$file" ]; then
        echo "0"
        return
    fi
    jq -r '
        [
          (.blockingFindings // [])[],
          (.nonBlockingFindings // [])[]
        ]
        | map(
            select(
              ((.id // "") == "")
              or ((.title // "") == "")
              or ((.claim // "") == "")
              or (((.evidence // []) | length) == 0)
            )
          )
        | length
    ' "$file" 2>/dev/null
}

task_structured_review_findings_count() {
    local file="$1"
    local key="$2"
    if [ ! -f "$file" ]; then
        echo "0"
        return
    fi
    jq -r --arg key "$key" '(.[$key] // []) | length' "$file" 2>/dev/null
}

task_round_all_finding_ids_json() {
    local file="$1"
    if [ ! -f "$file" ]; then
        echo "[]"
        return
    fi
    jq -c '
        [
          (.reviewerStates.codex.blockingFindings // [])[],
          (.reviewerStates.codex.nonBlockingFindings // [])[],
          (.reviewerStates.claude.blockingFindings // [])[],
          (.reviewerStates.claude.nonBlockingFindings // [])[]
        ]
        | map(.id // "")
        | map(select(. != ""))
    ' "$file" 2>/dev/null
}

task_round_invalid_finding_count() {
    local file="$1"
    if [ ! -f "$file" ]; then
        echo "0"
        return
    fi
    jq -r '
        [
          (.reviewerStates.codex.blockingFindings // [])[],
          (.reviewerStates.codex.nonBlockingFindings // [])[],
          (.reviewerStates.claude.blockingFindings // [])[],
          (.reviewerStates.claude.nonBlockingFindings // [])[]
        ]
        | map(
            select(
              ((.id // "") == "")
              or ((.title // "") == "")
              or ((.claim // "") == "")
              or (((.evidence // []) | length) == 0)
            )
          )
        | length
    ' "$file" 2>/dev/null
}

task_round_duplicate_finding_ids_count() {
    local file="$1"
    if [ ! -f "$file" ]; then
        echo "0"
        return
    fi
    jq -r '
        [
          (.reviewerStates.codex.blockingFindings // [])[],
          (.reviewerStates.codex.nonBlockingFindings // [])[],
          (.reviewerStates.claude.blockingFindings // [])[],
          (.reviewerStates.claude.nonBlockingFindings // [])[]
        ]
        | map(.id // "")
        | map(select(. != ""))
        | group_by(.)
        | map(select(length > 1))
        | length
    ' "$file" 2>/dev/null
}

task_round_response_invalid_count() {
    local file="$1"
    if [ ! -f "$file" ]; then
        echo "0"
        return
    fi
    jq -r '
        (.implementerResponses // [])
        | map(
            select(
              ((.findingId // "") == "")
              or (
                (.status // "") != "confirmed"
                and (.status // "") != "rejected"
                and (.status // "") != "partially_applied"
              )
              or (((.verificationMethod // []) | length) == 0)
              or (((.evidence // []) | length) == 0)
              or ((.resolutionSummary // "") == "")
            )
          )
        | length
    ' "$file" 2>/dev/null
}

task_round_missing_response_count() {
    local file="$1"
    if [ ! -f "$file" ]; then
        echo "0"
        return
    fi
    jq -r '
        [
          (.reviewerStates.codex.blockingFindings // [])[],
          (.reviewerStates.codex.nonBlockingFindings // [])[],
          (.reviewerStates.claude.blockingFindings // [])[],
          (.reviewerStates.claude.nonBlockingFindings // [])[]
        ] as $findings
        | ($findings | map(.id // "") | map(select(. != ""))) as $ids
        | (.implementerResponses // []) as $responses
        | [ $ids[] | select(($responses | map(.findingId // "")) | index(.) | not) ]
        | length
    ' "$file" 2>/dev/null
}

task_round_orphan_response_count() {
    local file="$1"
    if [ ! -f "$file" ]; then
        echo "0"
        return
    fi
    jq -r '
        [
          (.reviewerStates.codex.blockingFindings // [])[],
          (.reviewerStates.codex.nonBlockingFindings // [])[],
          (.reviewerStates.claude.blockingFindings // [])[],
          (.reviewerStates.claude.nonBlockingFindings // [])[]
        ] as $findings
        | ($findings | map(.id // "") | map(select(. != ""))) as $ids
        | (.implementerResponses // [])
        | map(select(((.findingId // "") != "") and (($ids | index(.findingId // "")) | not)))
        | length
    ' "$file" 2>/dev/null
}

task_phase_required_files() {
    local repo="$1"
    local slug="$2"
    local phase="$3"
    local dir
    dir=$(task_dir "$repo" "$slug")

    case "$phase" in
        plan)
            printf '%s\n' \
                "$dir/proposal.md" \
                "$dir/plan.md" \
                "$dir/plan-review-codex.md" \
                "$dir/plan-review-codex.state.json" \
                "$dir/plan-review-claude.md" \
                "$dir/plan-review-claude.state.json" \
                "$dir/verification-contract.md"
            ;;
        implementation)
            printf '%s\n' \
                "$dir/implementation-notes.md" \
                "$dir/implementation-review-codex.md" \
                "$dir/implementation-review-codex.state.json" \
                "$dir/implementation-review-claude.md" \
                "$dir/implementation-review-claude.state.json" \
                "$dir/verification-contract.md"
            ;;
        *)
            return 1
            ;;
    esac
}

task_validate_phase() {
    local repo="$1"
    local slug="$2"
    local phase="$3"

    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    if [ ! -f "$meta_file" ]; then
        echo "Task not found: $repo/$slug"
        exit 1
    fi

    local failures=()
    local file
    while IFS= read -r file; do
        if [ ! -f "$file" ]; then
            failures+=("missing:$(basename "$file")")
        elif ! task_file_has_meaningful_content "$file"; then
            failures+=("placeholder:$(basename "$file")")
        fi
    done < <(task_phase_required_files "$repo" "$slug" "$phase")

    local dir
    dir=$(task_dir "$repo" "$slug")
    if [ "$phase" = "plan" ] && task_has_open_checkboxes "$dir/plan-open-issues.md"; then
        failures+=("open_issues:plan-open-issues.md")
    fi

    if [ "$phase" = "plan" ]; then
        local slice_count
        slice_count=$(task_slice_count "$repo" "$slug")
        if [ "$slice_count" -lt 1 ]; then
            failures+=("missing_commit_slices:$TASK_SLICE_DIR_NAME")
        fi
        if ! task_section_has_meaningful_content "$dir/plan.md" "Commit Slices"; then
            failures+=("missing_commit_slice_definition_in_plan:plan.md")
        fi

        local slice_id
        while IFS= read -r slice_id; do
            [ -n "$slice_id" ] || continue
            local slice_md
            slice_md="$(task_slice_dir "$repo" "$slug" "$slice_id")/slice.md"
            if [ ! -f "$slice_md" ]; then
                failures+=("missing_slice_definition:$slice_id")
            elif ! task_file_has_meaningful_content "$slice_md"; then
                failures+=("placeholder_slice_definition:$slice_id")
            fi
        done < <(task_slice_list "$repo" "$slug")
    fi

    local codex_decision=""
    local claude_decision=""
    local codex_note=""
    local claude_note=""
    if [ "$phase" = "plan" ]; then
        local plan_codex_state plan_claude_state
        plan_codex_state=$(task_review_state_file "$repo" "$slug" "plan-codex")
        plan_claude_state=$(task_review_state_file "$repo" "$slug" "plan-claude")
        codex_decision=$(task_structured_review_decision "$plan_codex_state")
        claude_decision=$(task_structured_review_decision "$plan_claude_state")
        codex_note="read from $(basename "$plan_codex_state")"
        claude_note="read from $(basename "$plan_claude_state")"

        if [ ! -f "$plan_codex_state" ]; then
            failures+=("missing:$(basename "$plan_codex_state")")
        fi
        if [ ! -f "$plan_claude_state" ]; then
            failures+=("missing:$(basename "$plan_claude_state")")
        fi
        if [ -f "$plan_codex_state" ] && [ "$(task_structured_review_findings_invalid_count "$plan_codex_state")" -gt 0 ]; then
            failures+=("invalid_review_state:$(basename "$plan_codex_state")")
        fi
        if [ -f "$plan_claude_state" ] && [ "$(task_structured_review_findings_invalid_count "$plan_claude_state")" -gt 0 ]; then
            failures+=("invalid_review_state:$(basename "$plan_claude_state")")
        fi

        case "$codex_decision" in
            approved)
                if [ "$(task_structured_review_findings_count "$plan_codex_state" "blockingFindings")" -gt 0 ]; then
                    failures+=("review_state_conflict:$(basename "$plan_codex_state")")
                fi
                ;;
            blocked)
                if [ "$(task_structured_review_findings_count "$plan_codex_state" "blockingFindings")" -lt 1 ]; then
                    failures+=("missing_blocking_findings:$(basename "$plan_codex_state")")
                else
                    failures+=("review_blockers:plan-review-codex.md")
                fi
                ;;
            pending) failures+=("review_decision_pending:plan-review-codex.md") ;;
            invalid) failures+=("review_decision_invalid:$(basename "$plan_codex_state")") ;;
            missing) failures+=("missing_decision:$(basename "$plan_codex_state")") ;;
        esac
        case "$claude_decision" in
            approved)
                if [ "$(task_structured_review_findings_count "$plan_claude_state" "blockingFindings")" -gt 0 ]; then
                    failures+=("review_state_conflict:$(basename "$plan_claude_state")")
                fi
                ;;
            blocked)
                if [ "$(task_structured_review_findings_count "$plan_claude_state" "blockingFindings")" -lt 1 ]; then
                    failures+=("missing_blocking_findings:$(basename "$plan_claude_state")")
                else
                    failures+=("review_blockers:plan-review-claude.md")
                fi
                ;;
            pending) failures+=("review_decision_pending:plan-review-claude.md") ;;
            invalid) failures+=("review_decision_invalid:$(basename "$plan_claude_state")") ;;
            missing) failures+=("missing_decision:$(basename "$plan_claude_state")") ;;
        esac
    else
        local impl_codex_state impl_claude_state
        impl_codex_state=$(task_review_state_file "$repo" "$slug" "implementation-codex")
        impl_claude_state=$(task_review_state_file "$repo" "$slug" "implementation-claude")
        codex_decision=$(task_structured_review_decision "$impl_codex_state")
        claude_decision=$(task_structured_review_decision "$impl_claude_state")
        codex_note="read from $(basename "$impl_codex_state")"
        claude_note="read from $(basename "$impl_claude_state")"

        if [ ! -f "$impl_codex_state" ]; then
            failures+=("missing:$(basename "$impl_codex_state")")
        fi
        if [ ! -f "$impl_claude_state" ]; then
            failures+=("missing:$(basename "$impl_claude_state")")
        fi
        if [ -f "$impl_codex_state" ] && [ "$(task_structured_review_findings_invalid_count "$impl_codex_state")" -gt 0 ]; then
            failures+=("invalid_review_state:$(basename "$impl_codex_state")")
        fi
        if [ -f "$impl_claude_state" ] && [ "$(task_structured_review_findings_invalid_count "$impl_claude_state")" -gt 0 ]; then
            failures+=("invalid_review_state:$(basename "$impl_claude_state")")
        fi

        case "$codex_decision" in
            approved)
                if [ "$(task_structured_review_findings_count "$impl_codex_state" "blockingFindings")" -gt 0 ]; then
                    failures+=("review_state_conflict:$(basename "$impl_codex_state")")
                fi
                ;;
            blocked)
                if [ "$(task_structured_review_findings_count "$impl_codex_state" "blockingFindings")" -lt 1 ]; then
                    failures+=("missing_blocking_findings:$(basename "$impl_codex_state")")
                else
                    failures+=("review_blockers:implementation-review-codex.md")
                fi
                ;;
            pending) failures+=("review_decision_pending:implementation-review-codex.md") ;;
            invalid) failures+=("review_decision_invalid:$(basename "$impl_codex_state")") ;;
            missing) failures+=("missing_decision:$(basename "$impl_codex_state")") ;;
        esac
        case "$claude_decision" in
            approved)
                if [ "$(task_structured_review_findings_count "$impl_claude_state" "blockingFindings")" -gt 0 ]; then
                    failures+=("review_state_conflict:$(basename "$impl_claude_state")")
                fi
                ;;
            blocked)
                if [ "$(task_structured_review_findings_count "$impl_claude_state" "blockingFindings")" -lt 1 ]; then
                    failures+=("missing_blocking_findings:$(basename "$impl_claude_state")")
                else
                    failures+=("review_blockers:implementation-review-claude.md")
                fi
                ;;
            pending) failures+=("review_decision_pending:implementation-review-claude.md") ;;
            invalid) failures+=("review_decision_invalid:$(basename "$impl_claude_state")") ;;
            missing) failures+=("missing_decision:$(basename "$impl_claude_state")") ;;
        esac

        local locked_plan_hash current_plan_hash
        locked_plan_hash=$(jq -r '.lock.planHash // empty' "$meta_file" 2>/dev/null)
        current_plan_hash=$(task_hash_file "$dir/plan.md")
        if [ -n "$locked_plan_hash" ] && [ -n "$current_plan_hash" ] && [ "$locked_plan_hash" != "$current_plan_hash" ]; then
            failures+=("plan_drift:plan.md")
        fi

        local target_dir
        target_dir=$(task_target_git_dir "$repo" "$slug")
        if [ -d "$target_dir" ] && git -C "$target_dir" rev-parse --git-dir >/dev/null 2>&1; then
            if ! task_git_worktree_clean "$target_dir"; then
                failures+=("worktree_dirty:$target_dir")
            fi
        fi

        local slice_id
        while IFS= read -r slice_id; do
            [ -n "$slice_id" ] || continue
            local slice_meta slice_status slice_commit
            slice_meta=$(task_slice_meta_file "$repo" "$slug" "$slice_id")
            if [ ! -f "$slice_meta" ]; then
                failures+=("missing_slice_status:$slice_id")
                continue
            fi
            slice_status=$(jq -r '.status // "unknown"' "$slice_meta" 2>/dev/null)
            slice_commit=$(jq -r '.commit // empty' "$slice_meta" 2>/dev/null)
            if [ "$slice_status" != "committed" ]; then
                failures+=("slice_not_committed:$slice_id")
                continue
            fi
            if [ -z "$slice_commit" ]; then
                failures+=("slice_missing_commit:$slice_id")
                continue
            fi
            local commit_check
            commit_check=$(task_slice_verify_commit_against_git "$repo" "$slug" "$slice_id" "$slice_commit")
            if [ $? -ne 0 ]; then
                failures+=("slice_commit_invalid:$slice_id:$commit_check")
            fi
        done < <(task_slice_list "$repo" "$slug")
    fi

    local failures_json="[]"
    if [ ${#failures[@]} -gt 0 ]; then
        failures_json=$(printf '%s\n' "${failures[@]}" | jq -R . | jq -s '.')
    fi

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local tmp
    tmp=$(mktemp)
    jq \
        --arg phase "$phase" \
        --arg now "$now" \
        --argjson failures "$failures_json" \
        --arg codexDecision "$codex_decision" \
        --arg codexNote "$codex_note" \
        --arg claudeDecision "$claude_decision" \
        --arg claudeNote "$claude_note" \
        '
        .validation[$phase].lastRunAt = $now
        | .validation[$phase].failures = $failures
        | .validation[$phase].passed = (($failures | length) == 0)
        | if $phase == "plan" then
            .approvals.plan["plan-review-codex"] = {decision: $codexDecision, note: $codexNote, at: $now, source: "inferred"}
            | .approvals.plan["plan-critic-claude"] = {decision: $claudeDecision, note: $claudeNote, at: $now, source: "inferred"}
          else
            .approvals.implementation["implementation-review-codex"] = {decision: $codexDecision, note: $codexNote, at: $now, source: "inferred"}
            | .approvals.implementation["implementation-critic-claude"] = {decision: $claudeDecision, note: $claudeNote, at: $now, source: "inferred"}
          end
        ' \
        "$meta_file" > "$tmp" && mv "$tmp" "$meta_file"

    if [ ${#failures[@]} -eq 0 ]; then
        echo "Validation passed: $repo/$slug ($phase)"
        return 0
    fi

    echo "Validation failed: $repo/$slug ($phase)"
    printf '  - %s\n' "${failures[@]}"
    return 1
}

task_signoff() {
    local repo="$1"
    local slug="$2"
    local phase="$3"
    local role="$4"
    local decision="$5"
    local note="${6:-}"

    if [ -z "$repo" ] || [ -z "$slug" ] || [ -z "$phase" ] || [ -z "$role" ] || [ -z "$decision" ]; then
        echo "Usage: dev task signoff <repo> <slug> <plan|implementation> <role> <approved|blocked|revoked> [note]"
        exit 1
    fi

    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    if [ ! -f "$meta_file" ]; then
        echo "Task not found: $repo/$slug"
        exit 1
    fi

    case "$phase:$role" in
        plan:plan-review-codex|plan:plan-critic-claude|implementation:implementation-review-codex|implementation:implementation-critic-claude)
            ;;
        *)
            echo "Invalid phase/role combination: $phase / $role"
            exit 1
            ;;
    esac

    case "$decision" in
        approved|blocked|revoked)
            ;;
        *)
            echo "Decision must be one of: approved, blocked, revoked"
            exit 1
            ;;
    esac

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local tmp
    tmp=$(mktemp)
    jq \
        --arg phase "$phase" \
        --arg role "$role" \
        --arg decision "$decision" \
        --arg note "$note" \
        --arg now "$now" \
        '
        .approvals[$phase][$role] = {
          decision: $decision,
          note: $note,
          at: $now,
          source: "manual"
        }
        ' \
        "$meta_file" > "$tmp" && mv "$tmp" "$meta_file"

    echo "Recorded signoff: $repo/$slug $phase $role -> $decision"
}

task_slice_new() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"

    if [ -z "$repo" ] || [ -z "$slug" ] || [ -z "$slice_id" ]; then
        echo "Usage: dev task slice new <repo> <slug> <slice-id>"
        exit 1
    fi

    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    if [ ! -f "$meta_file" ]; then
        echo "Task not found: $repo/$slug"
        exit 1
    fi

    local safe_id
    safe_id=$(task_safe "$slice_id")
    local dir
    dir=$(task_slice_dir "$repo" "$slug" "$safe_id")
    if [ -d "$dir" ]; then
        echo "Slice already exists: $repo/$slug/$safe_id"
        exit 1
    fi

    mkdir -p "$dir"
    cat > "$dir/status.json" <<EOF
{
  "id": "$safe_id",
  "status": "planned",
  "currentRound": 1,
  "approvedToCommit": false,
  "commit": null,
  "validation": {
    "passed": false,
    "lastRunAt": null,
    "failures": []
  },
  "approvals": {
    "review-codex": null,
    "review-claude": null
  },
  "verification": {
    "lastRun": {
      "at": null,
      "targetDir": null,
      "commands": [],
      "failures": [],
      "success": false
    }
  }
}
EOF

    local rounds_dir round_dir
    rounds_dir="$dir/rounds"
    round_dir="$rounds_dir/$(task_slice_round_name 1)"
    mkdir -p "$round_dir"

    cat > "$dir/slice.md" <<EOF
# Slice: $safe_id

## Goal

## Commit Boundary

## Scope / Files

## Acceptance Criteria

## Verification
EOF

    cat > "$round_dir/review-codex.md" <<'EOF'
# Codex Slice Review

Use `state.json` in this round directory for the authoritative structured review state.

## Narrative Review

Summarize reasoning, evidence, tradeoffs, and any context around the findings recorded in the state file.
EOF

    cat > "$round_dir/review-claude.md" <<'EOF'
# Claude Slice Critique

Use `state.json` in this round directory for the authoritative structured review state.

## Narrative Review

Summarize reasoning, evidence, tradeoffs, and any context around the findings recorded in the state file.
EOF

    cat > "$round_dir/implementer-response.md" <<'EOF'
# Implementer Response

Use `state.json` in this round directory for the authoritative finding-by-finding verification state.

## Narrative Response

## Additional Context
EOF

    cat > "$round_dir/state.json" <<'EOF'
{
  "round": 1,
  "reviewerStates": {
    "codex": {
      "decision": "pending",
      "blockingFindings": [],
      "nonBlockingFindings": [],
      "summary": "",
      "updatedAt": null
    },
    "claude": {
      "decision": "pending",
      "blockingFindings": [],
      "nonBlockingFindings": [],
      "summary": "",
      "updatedAt": null
    }
  },
  "implementerResponses": [],
  "verification": {
    "lastRun": {
      "at": null,
      "commands": [],
      "failures": [],
      "success": false
    }
  }
}
EOF

    cat > "$dir/verification.md" <<'EOF'
# Slice Verification

Add fenced bash/sh commands for the checks that must pass before this slice may be committed.
EOF

    echo "Slice created: $repo/$slug/$safe_id"
}

task_slice_create_round() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"
    local round="$4"

    local round_dir
    round_dir=$(task_slice_round_dir "$repo" "$slug" "$slice_id" "$round")
    mkdir -p "$round_dir"

    cat > "$round_dir/review-codex.md" <<EOF
# Codex Slice Review

Use \`state.json\` in this round directory for the authoritative structured review state.

## Narrative Review

Round $(task_slice_round_name "$round"): summarize reasoning, evidence, tradeoffs, and any context around the findings recorded in the state file.
EOF

    cat > "$round_dir/review-claude.md" <<EOF
# Claude Slice Critique

Use \`state.json\` in this round directory for the authoritative structured review state.

## Narrative Review

Round $(task_slice_round_name "$round"): summarize reasoning, evidence, tradeoffs, and any context around the findings recorded in the state file.
EOF

    cat > "$round_dir/implementer-response.md" <<EOF
# Implementer Response

Use \`state.json\` in this round directory for the authoritative finding-by-finding verification state.

## Narrative Response

Round $(task_slice_round_name "$round"): summarize what you confirmed, rejected, or only partially applied and why.

## Additional Context
EOF

    cat > "$round_dir/state.json" <<EOF
{
  "round": $round,
  "reviewerStates": {
    "codex": {
      "decision": "pending",
      "blockingFindings": [],
      "nonBlockingFindings": [],
      "summary": "",
      "updatedAt": null
    },
    "claude": {
      "decision": "pending",
      "blockingFindings": [],
      "nonBlockingFindings": [],
      "summary": "",
      "updatedAt": null
    }
  },
  "implementerResponses": [],
  "verification": {
    "lastRun": {
      "at": null,
      "commands": [],
      "failures": [],
      "success": false
    }
  }
}
EOF
}

task_slice_start() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"

    if [ -z "$repo" ] || [ -z "$slug" ] || [ -z "$slice_id" ]; then
        echo "Usage: dev task slice start <repo> <slug> <slice-id>"
        exit 1
    fi

    local task_meta
    task_meta=$(task_meta_file "$repo" "$slug")
    if [ ! -f "$task_meta" ]; then
        echo "Task not found: $repo/$slug"
        exit 1
    fi

    local task_status
    task_status=$(jq -r '.status // "unknown"' "$task_meta" 2>/dev/null)
    if [ "$task_status" != "implementation_in_progress" ]; then
        echo "Task is not in implementation_in_progress: $repo/$slug"
        exit 1
    fi

    task_require_current_slice "$repo" "$slug" "$slice_id" || exit 1

    local meta_file
    meta_file=$(task_slice_meta_file "$repo" "$slug" "$slice_id")
    if [ ! -f "$meta_file" ]; then
        echo "Slice not found: $repo/$slug/$slice_id"
        exit 1
    fi

    task_set_json "$meta_file" '.status = "in_implementation" | .approvedToCommit = false | .commit = null'
    echo "Slice started: $repo/$slug/$slice_id"
}

task_slice_request_revision() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"

    if [ -z "$repo" ] || [ -z "$slug" ] || [ -z "$slice_id" ]; then
        echo "Usage: dev task slice request-revision <repo> <slug> <slice-id>"
        exit 1
    fi

    task_require_current_slice "$repo" "$slug" "$slice_id" || exit 1
    local meta_file
    meta_file=$(task_slice_meta_file "$repo" "$slug" "$slice_id")
    [ -f "$meta_file" ] || { echo "Slice not found: $repo/$slug/$slice_id"; exit 1; }

    local next_round
    next_round=$(( $(jq -r '.currentRound // 1' "$meta_file" 2>/dev/null) + 1 ))
    task_slice_create_round "$repo" "$slug" "$slice_id" "$next_round"
    task_set_json "$meta_file" ".status = \"revision_requested\" | .approvedToCommit = false | .currentRound = $next_round"
    echo "Slice moved to revision_requested: $repo/$slug/$slice_id"
}

task_slice_reopen() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"

    if [ -z "$repo" ] || [ -z "$slug" ] || [ -z "$slice_id" ]; then
        echo "Usage: dev task slice reopen <repo> <slug> <slice-id>"
        exit 1
    fi

    task_require_current_slice "$repo" "$slug" "$slice_id" || exit 1
    local meta_file
    meta_file=$(task_slice_meta_file "$repo" "$slug" "$slice_id")
    [ -f "$meta_file" ] || { echo "Slice not found: $repo/$slug/$slice_id"; exit 1; }
    task_set_json "$meta_file" '.status = "in_implementation" | .approvedToCommit = false'
    echo "Slice reopened: $repo/$slug/$slice_id"
}

task_slice_status() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"

    if [ -z "$repo" ] || [ -z "$slug" ] || [ -z "$slice_id" ]; then
        echo "Usage: dev task slice status <repo> <slug> <slice-id>"
        exit 1
    fi

    local meta_file
    meta_file=$(task_slice_meta_file "$repo" "$slug" "$slice_id")
    if [ ! -f "$meta_file" ]; then
        echo "Slice not found: $repo/$slug/$slice_id"
        exit 1
    fi

    local dir
    dir=$(task_slice_dir "$repo" "$slug" "$slice_id")
    local round
    round=$(jq -r '.currentRound // 1' "$meta_file" 2>/dev/null)
    local round_state
    round_state=$(task_slice_round_state_file "$repo" "$slug" "$slice_id" "$round")
    local status approved commit verify_ok
    status=$(jq -r '.status // "unknown"' "$meta_file" 2>/dev/null)
    approved=$(jq -r '.approvedToCommit // false' "$meta_file" 2>/dev/null)
    commit=$(jq -r '.commit // empty' "$meta_file" 2>/dev/null)
    verify_ok=$(jq -r ".verification.lastRun.success // false" "$meta_file" 2>/dev/null)

    echo -e "${BOLD}Slice:${RESET} $repo/$slug/$slice_id"
    echo -e "${DIM}Dir:${RESET} $dir"
    echo -e "${DIM}Status:${RESET} $status"
    echo -e "${DIM}Current round:${RESET} $(task_slice_round_name "$round")"
    echo -e "${DIM}Approved to commit:${RESET} $approved"
    echo -e "${DIM}Verification success:${RESET} $verify_ok"
    if [ -n "$commit" ]; then
        echo -e "${DIM}Commit:${RESET} $commit"
    fi
    echo ""
    echo "Approvals:"
    echo "  review-codex: $(jq -r '.reviewerStates.codex.decision // "pending"' "$round_state" 2>/dev/null)"
    echo "  review-claude: $(jq -r '.reviewerStates.claude.decision // "pending"' "$round_state" 2>/dev/null)"
    echo ""
    echo "Validation:"
    echo "  passed: $(jq -r '.validation.passed // false' "$meta_file" 2>/dev/null)"
    jq -r '.validation.failures[]? // empty' "$meta_file" 2>/dev/null | sed 's/^/    - /'
}

task_slice_validate() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"

    if [ -z "$repo" ] || [ -z "$slug" ] || [ -z "$slice_id" ]; then
        echo "Usage: dev task slice validate <repo> <slug> <slice-id>"
        exit 1
    fi

    local meta_file
    meta_file=$(task_slice_meta_file "$repo" "$slug" "$slice_id")
    if [ ! -f "$meta_file" ]; then
        echo "Slice not found: $repo/$slug/$slice_id"
        exit 1
    fi

    task_require_current_slice "$repo" "$slug" "$slice_id" || exit 1

    local dir
    dir=$(task_slice_dir "$repo" "$slug" "$slice_id")
    local round
    round=$(jq -r '.currentRound // 1' "$meta_file" 2>/dev/null)
    local round_dir round_state
    round_dir=$(task_slice_round_dir "$repo" "$slug" "$slice_id" "$round")
    round_state=$(task_slice_round_state_file "$repo" "$slug" "$slice_id" "$round")
    local failures=()

    local f
    for f in slice.md verification.md; do
        if [ ! -f "$dir/$f" ]; then
            failures+=("missing:$f")
        elif ! task_file_has_meaningful_content "$dir/$f"; then
            failures+=("placeholder:$f")
        fi
    done
    for f in review-codex.md review-claude.md implementer-response.md state.json; do
        if [ ! -f "$round_dir/$f" ]; then
            failures+=("missing:$(task_slice_round_name "$round")/$f")
        elif [ "$f" != "state.json" ] && ! task_file_has_meaningful_content "$round_dir/$f"; then
            failures+=("placeholder:$(task_slice_round_name "$round")/$f")
        fi
    done

    local codex_decision claude_decision
    codex_decision=$(jq -r '.reviewerStates.codex.decision // "missing"' "$round_state" 2>/dev/null | tr '[:upper:]' '[:lower:]')
    claude_decision=$(jq -r '.reviewerStates.claude.decision // "missing"' "$round_state" 2>/dev/null | tr '[:upper:]' '[:lower:]')

    if [ -f "$round_state" ]; then
        if [ "$(task_round_invalid_finding_count "$round_state")" -gt 0 ]; then
            failures+=("invalid_round_findings:$(task_slice_round_name "$round")/state.json")
        fi
        if [ "$(task_round_duplicate_finding_ids_count "$round_state")" -gt 0 ]; then
            failures+=("duplicate_finding_ids:$(task_slice_round_name "$round")/state.json")
        fi
        if [ "$(task_round_response_invalid_count "$round_state")" -gt 0 ]; then
            failures+=("invalid_implementer_responses:$(task_slice_round_name "$round")/state.json")
        fi
        if [ "$(task_round_missing_response_count "$round_state")" -gt 0 ]; then
            failures+=("missing_implementer_responses:$(task_slice_round_name "$round")/state.json")
        fi
        if [ "$(task_round_orphan_response_count "$round_state")" -gt 0 ]; then
            failures+=("orphan_implementer_responses:$(task_slice_round_name "$round")/state.json")
        fi
    fi

    case "$codex_decision" in
        approved)
            if [ "$(jq -r '(.reviewerStates.codex.blockingFindings // []) | length' "$round_state" 2>/dev/null)" -gt 0 ]; then
                failures+=("review_state_conflict:$(task_slice_round_name "$round")/state.json:codex")
            fi
            ;;
        blocked)
            if [ "$(jq -r '(.reviewerStates.codex.blockingFindings // []) | length' "$round_state" 2>/dev/null)" -lt 1 ]; then
                failures+=("missing_blocking_findings:$(task_slice_round_name "$round")/state.json:codex")
            else
                failures+=("review_blockers:$(task_slice_round_name "$round")/review-codex.md")
            fi
            ;;
        pending) failures+=("review_decision_pending:$(task_slice_round_name "$round")/state.json:codex") ;;
        missing) failures+=("missing_decision:$(task_slice_round_name "$round")/state.json:codex") ;;
        *) failures+=("review_decision_invalid:$(task_slice_round_name "$round")/state.json:codex") ;;
    esac
    case "$claude_decision" in
        approved)
            if [ "$(jq -r '(.reviewerStates.claude.blockingFindings // []) | length' "$round_state" 2>/dev/null)" -gt 0 ]; then
                failures+=("review_state_conflict:$(task_slice_round_name "$round")/state.json:claude")
            fi
            ;;
        blocked)
            if [ "$(jq -r '(.reviewerStates.claude.blockingFindings // []) | length' "$round_state" 2>/dev/null)" -lt 1 ]; then
                failures+=("missing_blocking_findings:$(task_slice_round_name "$round")/state.json:claude")
            else
                failures+=("review_blockers:$(task_slice_round_name "$round")/review-claude.md")
            fi
            ;;
        pending) failures+=("review_decision_pending:$(task_slice_round_name "$round")/state.json:claude") ;;
        missing) failures+=("missing_decision:$(task_slice_round_name "$round")/state.json:claude") ;;
        *) failures+=("review_decision_invalid:$(task_slice_round_name "$round")/state.json:claude") ;;
    esac

    if [ ! -f "$round_state" ]; then
        failures+=("missing:$(task_slice_round_name "$round")/state.json")
    fi

    local target_dir
    target_dir=$(task_target_dir "$repo" "$slug" "implementer-codex")
    if [ -z "$target_dir" ]; then
        target_dir=$(repo_base_dir "$repo")
    fi

    local slice_file
    slice_file="$dir/slice.md"
    local scopes=()
    local scope_entry
    while IFS= read -r scope_entry; do
        [ -n "$scope_entry" ] || continue
        scopes+=("$scope_entry")
    done < <(task_slice_scope_entries "$slice_file")
    if [ ${#scopes[@]} -eq 0 ]; then
        failures+=("missing_scope_entries:slice.md")
    elif [ -d "$target_dir" ] && git -C "$target_dir" rev-parse --git-dir >/dev/null 2>&1; then
        local changed_file
        while IFS= read -r changed_file; do
            [ -n "$changed_file" ] || continue
            if ! task_slice_file_in_scope "$changed_file" "${scopes[@]}"; then
                failures+=("out_of_scope_worktree_file:$changed_file")
            fi
        done < <(task_git_changed_files "$target_dir")
    fi

    local commands
    commands=$(task_slice_extract_verification_commands "$repo" "$slug" "$slice_id")
    if [ -z "$commands" ]; then
        failures+=("missing_verification_commands:verification.md")
    fi

    local executed=()
    local verify_failures=()
    local cmd
    while IFS= read -r cmd; do
        [ -z "$cmd" ] && continue
        [[ "$cmd" =~ ^[[:space:]]*# ]] && continue
        executed+=("$cmd")
        echo "Running slice check: $cmd"
        if ! (cd "$target_dir" && bash -lc "$cmd"); then
            verify_failures+=("$cmd")
            failures+=("verification_failed:$cmd")
        fi
    done <<< "$commands"

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local failures_json executed_json verify_failures_json
    failures_json=$(task_slice_validation_failures_json "${failures[@]}")
    if [ ${#executed[@]} -gt 0 ]; then
        executed_json=$(printf '%s\n' "${executed[@]}" | jq -R . | jq -s '.')
    else
        executed_json='[]'
    fi
    if [ ${#verify_failures[@]} -gt 0 ]; then
        verify_failures_json=$(printf '%s\n' "${verify_failures[@]}" | jq -R . | jq -s '.')
    else
        verify_failures_json='[]'
    fi

    local tmp
    tmp=$(mktemp)
    jq \
        --arg now "$now" \
        --arg codexDecision "$codex_decision" \
        --arg claudeDecision "$claude_decision" \
        --argjson failures "$failures_json" \
        --argjson executed "$executed_json" \
        --argjson verifyFailures "$verify_failures_json" \
        '
        .validation = {
          passed: (($failures | length) == 0),
          lastRunAt: $now,
          failures: $failures
        }
        | .approvals["review-codex"] = {decision: $codexDecision, at: $now, source: "inferred"}
        | .approvals["review-claude"] = {decision: $claudeDecision, at: $now, source: "inferred"}
        | .verification.lastRun = {
            at: $now,
            commands: $executed,
            failures: $verifyFailures,
            success: (($verifyFailures | length) == 0)
          }
        | .status = (if ($failures | length) == 0 then "in_review" else "revision_requested" end)
        ' \
        "$meta_file" > "$tmp" && mv "$tmp" "$meta_file"

    if [ -f "$round_state" ]; then
        local round_tmp
        round_tmp=$(mktemp)
        jq \
            --arg now "$now" \
            --argjson executed "$executed_json" \
            --argjson verifyFailures "$verify_failures_json" \
            '
            .verification.lastRun = {
              at: $now,
              commands: $executed,
              failures: $verifyFailures,
              success: (($verifyFailures | length) == 0)
            }
            ' \
            "$round_state" > "$round_tmp" && mv "$round_tmp" "$round_state"
    fi

    if [ ${#failures[@]} -eq 0 ]; then
        echo "Slice validation passed: $repo/$slug/$slice_id"
        return 0
    fi

    echo "Slice validation failed: $repo/$slug/$slice_id"
    printf '  - %s\n' "${failures[@]}"
    return 1
}

task_slice_approve_commit() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"

    if [ -z "$repo" ] || [ -z "$slug" ] || [ -z "$slice_id" ]; then
        echo "Usage: dev task slice approve-commit <repo> <slug> <slice-id>"
        exit 1
    fi

    local meta_file
    meta_file=$(task_slice_meta_file "$repo" "$slug" "$slice_id")
    if [ ! -f "$meta_file" ]; then
        echo "Slice not found: $repo/$slug/$slice_id"
        exit 1
    fi

    task_require_current_slice "$repo" "$slug" "$slice_id" || exit 1

    task_slice_validate "$repo" "$slug" "$slice_id" || exit 1

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    task_set_json "$meta_file" ".approvedToCommit = true | .status = \"approved_to_commit\" | .approvedAt = \"$now\""
    echo "Slice approved to commit: $repo/$slug/$slice_id"
}

task_slice_committed() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"
    local commit_ref="$4"

    if [ -z "$repo" ] || [ -z "$slug" ] || [ -z "$slice_id" ] || [ -z "$commit_ref" ]; then
        echo "Usage: dev task slice committed <repo> <slug> <slice-id> <commit>"
        exit 1
    fi

    local meta_file
    meta_file=$(task_slice_meta_file "$repo" "$slug" "$slice_id")
    if [ ! -f "$meta_file" ]; then
        echo "Slice not found: $repo/$slug/$slice_id"
        exit 1
    fi

    task_require_current_slice "$repo" "$slug" "$slice_id" || exit 1

    local approved
    approved=$(jq -r '.approvedToCommit // false' "$meta_file" 2>/dev/null)
    if [ "$approved" != "true" ]; then
        echo "Slice is not approved_to_commit: $repo/$slug/$slice_id"
        exit 1
    fi

    local commit_check
    commit_check=$(task_slice_verify_commit_against_git "$repo" "$slug" "$slice_id" "$commit_ref")
    if [ $? -ne 0 ]; then
        echo "Slice commit verification failed: $commit_check"
        exit 1
    fi

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    task_set_json "$meta_file" ".commit = \"$commit_ref\" | .committedAt = \"$now\" | .status = \"committed\""
    echo "Slice committed: $repo/$slug/$slice_id -> $commit_ref"
}

task_all_slices_committed() {
    local repo="$1"
    local slug="$2"
    local slice_id
    local count=0
    while IFS= read -r slice_id; do
        [ -n "$slice_id" ] || continue
        count=$((count + 1))
        local meta_file
        meta_file=$(task_slice_meta_file "$repo" "$slug" "$slice_id")
        if [ ! -f "$meta_file" ]; then
            return 1
        fi
        local status
        status=$(jq -r '.status // "unknown"' "$meta_file" 2>/dev/null)
        if [ "$status" != "committed" ]; then
            return 1
        fi
    done < <(task_slice_list "$repo" "$slug")

    [ "$count" -gt 0 ]
}

task_mark_ready_merge() {
    local repo="$1"
    local slug="$2"

    if [ -z "$repo" ] || [ -z "$slug" ]; then
        echo "Usage: dev task ready-merge <repo> <slug>"
        exit 1
    fi

    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    if [ ! -f "$meta_file" ]; then
        echo "Task not found: $repo/$slug"
        exit 1
    fi

    task_validate_phase "$repo" "$slug" implementation || exit 1
    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    if ! task_all_slices_committed "$repo" "$slug"; then
        echo "Not all slices are committed for $repo/$slug"
        echo "Each declared slice must reach committed before ready-merge."
        exit 1
    fi
    local verify_ok
    verify_ok=$(jq -r '.verification.lastRun.success // false' "$meta_file" 2>/dev/null)
    if [ "$verify_ok" != "true" ]; then
        echo "Verification has not passed for $repo/$slug"
        echo "Run: dev task verify $repo $slug"
        exit 1
    fi
    task_set_json "$meta_file" '.status = "ready_to_merge"'
    echo "Task ready to merge: $repo/$slug"
}

task_mark_merged() {
    local repo="$1"
    local slug="$2"
    local merge_ref="${3:-}"

    if [ -z "$repo" ] || [ -z "$slug" ]; then
        echo "Usage: dev task merged <repo> <slug> [merge-ref]"
        exit 1
    fi

    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    if [ ! -f "$meta_file" ]; then
        echo "Task not found: $repo/$slug"
        exit 1
    fi

    local status
    status=$(jq -r '.status // "unknown"' "$meta_file" 2>/dev/null)
    if [ "$status" != "ready_to_merge" ]; then
        echo "Task is not ready_to_merge: $repo/$slug (current: $status)"
        exit 1
    fi

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local tmp
    tmp=$(mktemp)
    jq \
        --arg now "$now" \
        --arg mergeRef "$merge_ref" \
        '
        .status = "merged"
        | .merged = {
            at: $now,
            ref: (if $mergeRef == "" then null else $mergeRef end)
          }
        ' \
        "$meta_file" > "$tmp" && mv "$tmp" "$meta_file"

    echo "Task marked merged: $repo/$slug"
}

task_close() {
    local repo="$1"
    local slug="$2"
    local mode="${3:-}"

    if [ -z "$repo" ] || [ -z "$slug" ]; then
        echo "Usage: dev task close <repo> <slug> [--cleanup]"
        exit 1
    fi

    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    if [ ! -f "$meta_file" ]; then
        echo "Task not found: $repo/$slug"
        exit 1
    fi

    local status
    local worktree
    status=$(jq -r '.status // "unknown"' "$meta_file" 2>/dev/null)
    worktree=$(jq -r '.worktree // empty' "$meta_file" 2>/dev/null)

    if [ "$status" != "merged" ]; then
        echo "Task is not merged: $repo/$slug (current: $status)"
        exit 1
    fi

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    task_set_json "$meta_file" ".status = \"closed\" | .closed = {at: \"$now\"}"

    if [ "$mode" = "--cleanup" ] && [ -n "$worktree" ]; then
        cleanup_worktree "$repo/$worktree"
    fi

    echo "Task closed: $repo/$slug"
}

task_next_actions() {
    local repo="$1"
    local slug="$2"
    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")

    local status
    local locked
    local plan_validation
    local impl_validation
    local verify_ok
    local slice_count
    status=$(jq -r '.status // "unknown"' "$meta_file" 2>/dev/null)
    locked=$(jq -r '.planLocked // false' "$meta_file" 2>/dev/null)
    plan_validation=$(jq -r '.validation.plan.passed // false' "$meta_file" 2>/dev/null)
    impl_validation=$(jq -r '.validation.implementation.passed // false' "$meta_file" 2>/dev/null)
    verify_ok=$(jq -r '.verification.lastRun.success // false' "$meta_file" 2>/dev/null)
    slice_count=$(task_slice_count "$repo" "$slug")

    if [ "$locked" != "true" ]; then
        if [ "$slice_count" -lt 1 ]; then
            echo "Declare commit slices before locking the plan: dev task slice new $repo $slug <slice-id>"
        fi
        echo "Resolve plan review docs and signoffs, then run: dev task validate $repo $slug plan"
        echo "When clean, run: dev task lock-plan $repo $slug"
        return
    fi

    if [ "$status" = "plan_locked" ]; then
        echo "Start implementation: dev task start-impl $repo $slug [worktree]"
        echo "Then orchestrate the implementer with: dev task send $repo $slug implementer-codex \"...\""
        return
    fi

    if [ "$status" = "implementation_in_progress" ]; then
        local next_slice=""
        while IFS= read -r next_slice; do
            [ -n "$next_slice" ] || continue
            local slice_meta
            slice_meta=$(task_slice_meta_file "$repo" "$slug" "$next_slice")
            local slice_status
            slice_status=$(jq -r '.status // "planned"' "$slice_meta" 2>/dev/null)
            if [ "$slice_status" != "committed" ]; then
                echo "Current slice checkpoint: dev task slice status $repo $slug $next_slice"
                if [ "$slice_status" = "planned" ]; then
                    echo "Begin this slice: dev task slice start $repo $slug $next_slice"
                fi
                echo "Run iterative slice review until approval: dev task slice validate $repo $slug $next_slice"
                echo "When satisfactory, authorize commit: dev task slice approve-commit $repo $slug $next_slice"
                echo "After the implementer commits, record it: dev task slice committed $repo $slug $next_slice <commit>"
                return
            fi
        done < <(task_slice_list "$repo" "$slug")

        echo "Run task review: dev task review $repo $slug"
        echo "Update implementation review docs, record signoffs, and run: dev task verify $repo $slug"
        return
    fi

    if [ "$status" = "ready_to_merge" ]; then
        echo "Merge the work, then record it: dev task merged $repo $slug [merge-ref]"
        echo "After merge, finish lifecycle: dev task close $repo $slug [--cleanup]"
        return
    fi

    if [ "$status" = "merged" ]; then
        echo "Finalize the task: dev task close $repo $slug [--cleanup]"
        return
    fi

    if [ "$status" = "closed" ]; then
        echo "Task lifecycle complete."
        return
    fi

    if [ "$impl_validation" != "true" ] || [ "$verify_ok" != "true" ]; then
        echo "Fix implementation review blockers or verification failures."
        echo "Then run: dev task validate $repo $slug implementation"
        echo "And: dev task verify $repo $slug"
        return
    fi

    echo "Mark merge-ready: dev task ready-merge $repo $slug"
}

list_repo_tasks() {
    local repo="$1"
    local base_dir
    base_dir=$(repo_base_dir "$repo")
    local tasks_dir="$base_dir/$TASK_ROOT_REL"

    if [ ! -d "$tasks_dir" ]; then
        return
    fi

    local printed=0
    local task_path
    for task_path in "$tasks_dir"/*; do
        [ -d "$task_path" ] || continue
        local slug
        local meta_file
        local status
        local locked
        local slices
        slug=$(basename "$task_path")
        meta_file="$task_path/task.json"
        status=$(jq -r '.status // "unknown"' "$meta_file" 2>/dev/null)
        locked=$(jq -r '.planLocked // false' "$meta_file" 2>/dev/null)
        slices=$(task_slice_count "$repo" "$slug")
        if [ "$printed" -eq 0 ]; then
            echo -e "      ${MAGENTA}Tasks${RESET}"
            printed=1
        fi
        echo -e "          └─ ${CYAN}$slug${RESET} ${DIM}[$status, planLocked=$locked, slices=$slices]${RESET}"
    done
}

list_repo_task_slugs() {
    local repo="$1"
    local base_dir
    base_dir=$(repo_base_dir "$repo")
    local tasks_dir="$base_dir/$TASK_ROOT_REL"
    if [ ! -d "$tasks_dir" ]; then
        return
    fi
    local task_path
    for task_path in "$tasks_dir"/*; do
        [ -d "$task_path" ] || continue
        basename "$task_path"
    done | sort
}

task_role_backend_label() {
    local repo="$1"
    local slug="$2"
    local role="$3"
    local session_path
    session_path=$(task_role_session_path "$repo" "$slug" "$role")
    local session_name
    session_name=$(to_session_name "$session_path")
    local backend
    backend=$(session_backend "$session_name")
    if [ -z "$backend" ]; then
        echo "not_started"
    else
        echo "$backend"
    fi
}

task_summary_line() {
    local repo="$1"
    local slug="$2"
    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    [ -f "$meta_file" ] || return

    local status worktree current_slice slice_status verify_ok
    status=$(jq -r '.status // "unknown"' "$meta_file" 2>/dev/null)
    worktree=$(jq -r '.worktree // empty' "$meta_file" 2>/dev/null)
    current_slice=$(task_current_slice "$repo" "$slug")
    if [ -n "$current_slice" ]; then
        slice_status=$(jq -r '.status // "unknown"' "$(task_slice_meta_file "$repo" "$slug" "$current_slice")" 2>/dev/null)
    else
        slice_status="-"
    fi
    verify_ok=$(jq -r '.verification.lastRun.success // false' "$meta_file" 2>/dev/null)
    echo "$slug|$status|${worktree:-main}|${current_slice:-none}|$slice_status|$verify_ok"
}

task_priority_bucket() {
    local repo="$1"
    local slug="$2"
    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    [ -f "$meta_file" ] || return

    local status locked
    status=$(jq -r '.status // "unknown"' "$meta_file" 2>/dev/null)
    locked=$(jq -r '.planLocked // false' "$meta_file" 2>/dev/null)

    if [ "$locked" != "true" ]; then
        echo "plan_work"
        return
    fi
    if [ "$status" = "ready_to_merge" ]; then
        echo "ready_to_merge"
        return
    fi
    if [ "$status" = "merged" ]; then
        echo "ready_to_close"
        return
    fi
    if [ "$status" = "implementation_in_progress" ]; then
        local current_slice
        current_slice=$(task_current_slice "$repo" "$slug")
        if [ -n "$current_slice" ]; then
            local slice_meta slice_status approved
            slice_meta=$(task_slice_meta_file "$repo" "$slug" "$current_slice")
            slice_status=$(jq -r '.status // "planned"' "$slice_meta" 2>/dev/null)
            approved=$(jq -r '.approvedToCommit // false' "$slice_meta" 2>/dev/null)
            if [ "$approved" = "true" ] || [ "$slice_status" = "approved_to_commit" ]; then
                echo "ready_for_slice_commit"
                return
            fi
            case "$slice_status" in
                revision_requested)
                    echo "waiting_on_implementer"
                    return
                    ;;
                in_review)
                    echo "waiting_on_orchestrator"
                    return
                    ;;
                planned|in_implementation)
                    echo "in_flight"
                    return
                    ;;
            esac
        fi
    fi
    echo "other"
}

project_conflicts() {
    local repo="$1"
    local warnings=()
    local slug_a slug_b

    while IFS= read -r slug_a; do
        [ -n "$slug_a" ] || continue
        local meta_a
        meta_a=$(task_meta_file "$repo" "$slug_a")
        local status_a worktree_a
        status_a=$(jq -r '.status // "unknown"' "$meta_a" 2>/dev/null)
        worktree_a=$(jq -r '.worktree // empty' "$meta_a" 2>/dev/null)

        if [ "$status_a" = "implementation_in_progress" ] && [ -n "$worktree_a" ]; then
            while IFS= read -r slug_b; do
                [ -n "$slug_b" ] || continue
                [ "$slug_a" = "$slug_b" ] && continue
                local meta_b status_b worktree_b
                meta_b=$(task_meta_file "$repo" "$slug_b")
                status_b=$(jq -r '.status // "unknown"' "$meta_b" 2>/dev/null)
                worktree_b=$(jq -r '.worktree // empty' "$meta_b" 2>/dev/null)
                if [ "$status_b" = "implementation_in_progress" ] && [ -n "$worktree_b" ] && [ "$worktree_a" = "$worktree_b" ]; then
                    warnings+=("shared_worktree:$slug_a:$slug_b:$worktree_a")
                fi
            done < <(list_repo_task_slugs "$repo")
        fi

        local target_a
        target_a=$(task_target_git_dir "$repo" "$slug_a")
        if [ "$status_a" = "implementation_in_progress" ] && [ -d "$target_a" ] && git -C "$target_a" rev-parse --git-dir >/dev/null 2>&1; then
            while IFS= read -r slug_b; do
                [ -n "$slug_b" ] || continue
                [[ "$slug_a" > "$slug_b" ]] || continue
                local meta_b status_b target_b
                meta_b=$(task_meta_file "$repo" "$slug_b")
                status_b=$(jq -r '.status // "unknown"' "$meta_b" 2>/dev/null)
                [ "$status_b" = "implementation_in_progress" ] || continue
                target_b=$(task_target_git_dir "$repo" "$slug_b")
                [ -d "$target_b" ] || continue
                git -C "$target_b" rev-parse --git-dir >/dev/null 2>&1 || continue

                local file_a
                while IFS= read -r file_a; do
                    [ -n "$file_a" ] || continue
                    local file_b
                    while IFS= read -r file_b; do
                        [ -n "$file_b" ] || continue
                        if [ "$file_a" = "$file_b" ]; then
                            warnings+=("overlapping_changed_file:$slug_a:$slug_b:$file_a")
                        fi
                    done < <(task_git_changed_files "$target_b")
                done < <(task_git_changed_files "$target_a")
            done < <(list_repo_task_slugs "$repo")
        fi

        local current_a
        current_a=$(task_current_slice "$repo" "$slug_a")
        if [ -n "$current_a" ]; then
            local slice_file_a
            slice_file_a="$(task_slice_dir "$repo" "$slug_a" "$current_a")/slice.md"
            local scopes_a=()
            local s_a
            while IFS= read -r s_a; do
                [ -n "$s_a" ] || continue
                scopes_a+=("$s_a")
            done < <(task_slice_scope_entries "$slice_file_a")

            while IFS= read -r slug_b; do
                [ -n "$slug_b" ] || continue
                [[ "$slug_a" > "$slug_b" ]] || continue
                local current_b
                current_b=$(task_current_slice "$repo" "$slug_b")
                [ -n "$current_b" ] || continue
                local slice_file_b
                slice_file_b="$(task_slice_dir "$repo" "$slug_b" "$current_b")/slice.md"
                local s_b
                while IFS= read -r s_b; do
                    [ -n "$s_b" ] || continue
                    local s1
                    for s1 in "${scopes_a[@]}"; do
                        [ -n "$s1" ] || continue
                        if [ "$s1" = "$s_b" ] || [[ "$s1" == "$s_b/"* ]] || [[ "$s_b" == "$s1/"* ]]; then
                            warnings+=("overlapping_scope:$slug_a:$current_a:$slug_b:$current_b:$s1:$s_b")
                        fi
                    done
                done < <(task_slice_scope_entries "$slice_file_b")
            done < <(list_repo_task_slugs "$repo")
        fi
    done < <(list_repo_task_slugs "$repo")

    printf '%s\n' "${warnings[@]}" | sed '/^$/d' | sort -u
}

project_tasks_dashboard() {
    local repo="$1"
    if [ -z "$repo" ]; then
        echo "Usage: dev project tasks <repo>"
        exit 1
    fi

    echo -e "${BOLD}Project Tasks:${RESET} $repo"
    local found=0
    local slug
    while IFS= read -r slug; do
        [ -n "$slug" ] || continue
        found=1
        IFS='|' read -r name status worktree current_slice slice_status verify_ok <<< "$(task_summary_line "$repo" "$slug")"
        local bucket
        bucket=$(task_priority_bucket "$repo" "$slug")
        echo "  - $name [status=$status, worktree=$worktree, currentSlice=$current_slice, sliceState=$slice_status, verify=$verify_ok, queue=$bucket]"
    done < <(list_repo_task_slugs "$repo")
    if [ "$found" -eq 0 ]; then
        echo "  - none"
    fi

    echo ""
    echo "Conflicts:"
    local warnings
    warnings=$(project_conflicts "$repo")
    if [ -n "$warnings" ]; then
        echo "$warnings" | sed 's/^/  - /'
    else
        echo "  - none"
    fi
}

project_review() {
    local repo="$1"
    if [ -z "$repo" ]; then
        echo "Usage: dev project review <repo>"
        exit 1
    fi

    project_tasks_dashboard "$repo"
    echo ""
    echo "Orchestrator queue:"
    local slug
    local found=0
    while IFS= read -r slug; do
        [ -n "$slug" ] || continue
        found=1
        local bucket
        bucket=$(task_priority_bucket "$repo" "$slug")
        echo "  - $slug: $bucket"
        task_next_actions "$repo" "$slug" | sed 's/^/      /'
    done < <(list_repo_task_slugs "$repo")
    if [ "$found" -eq 0 ]; then
        echo "  - none"
    fi
}

project_poll() {
    local repo="$1"
    if [ -z "$repo" ]; then
        echo "Usage: dev project poll <repo>"
        exit 1
    fi

    local slug
    local found=0
    while IFS= read -r slug; do
        [ -n "$slug" ] || continue
        found=1
        echo "=== $slug ==="
        task_poll "$repo" "$slug"
        echo ""
    done < <(list_repo_task_slugs "$repo")
    if [ "$found" -eq 0 ]; then
        echo "No tasks for project: $repo"
    fi
}

project_sessions() {
    local repo="$1"
    if [ -z "$repo" ]; then
        echo "Usage: dev project sessions <repo>"
        exit 1
    fi

    local slug
    local found=0
    while IFS= read -r slug; do
        [ -n "$slug" ] || continue
        found=1
        echo "$slug:"
        local role
        for role in plan-owner-codex plan-review-codex plan-critic-claude implementer-codex implementation-review-codex implementation-critic-claude; do
            echo "  - $role: $(task_role_session_path "$repo" "$slug" "$role") [$(task_role_backend_label "$repo" "$slug" "$role")]"
        done
    done < <(list_repo_task_slugs "$repo")
    if [ "$found" -eq 0 ]; then
        echo "No tasks for project: $repo"
    fi
}

task_sessions() {
    local repo="$1"
    local slug="$2"
    if [ -z "$repo" ] || [ -z "$slug" ]; then
        echo "Usage: dev task sessions <repo> <slug>"
        exit 1
    fi

    local role
    for role in plan-owner-codex plan-review-codex plan-critic-claude implementer-codex implementation-review-codex implementation-critic-claude; do
        echo "$role: $(task_role_session_path "$repo" "$slug" "$role") [$(task_role_backend_label "$repo" "$slug" "$role")]"
    done
}

task_open_current() {
    local repo="$1"
    local slug="$2"
    local role="${3:-}"
    if [ -z "$repo" ] || [ -z "$slug" ]; then
        echo "Usage: dev task open-current <repo> <slug> [role]"
        exit 1
    fi

    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    [ -f "$meta_file" ] || { echo "Task not found: $repo/$slug"; exit 1; }
    local status
    status=$(jq -r '.status // "unknown"' "$meta_file" 2>/dev/null)

    if [ -z "$role" ]; then
        if [ "$status" = "implementation_in_progress" ] || [ "$status" = "ready_to_merge" ] || [ "$status" = "merged" ]; then
            role="implementer-codex"
        else
            role="plan-owner-codex"
        fi
    fi
    task_role_open "$repo" "$slug" "$role"
}

task_open_slice() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"
    local role="${4:-implementer-codex}"
    if [ -z "$repo" ] || [ -z "$slug" ] || [ -z "$slice_id" ]; then
        echo "Usage: dev task open-slice <repo> <slug> <slice-id> [role]"
        exit 1
    fi
    task_require_current_slice "$repo" "$slug" "$slice_id" || exit 1
    task_role_open "$repo" "$slug" "$role"
}

task_role_session_path() {
    local repo="$1"
    local slug="$2"
    local role="$3"
    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    local worktree
    worktree=$(jq -r '.worktree // empty' "$meta_file" 2>/dev/null)

    if [[ "$role" == implementer-codex || "$role" == implementation-review-codex || "$role" == implementation-critic-claude ]]; then
        task_session_path "$repo" "$slug" "$role" "$worktree"
    else
        task_session_path "$repo" "$slug" "$role"
    fi
}

task_send() {
    local repo="$1"
    local slug="$2"
    local role="$3"
    shift 3
    local message="$*"

    if [ -z "$repo" ] || [ -z "$slug" ] || [ -z "$role" ] || [ -z "$message" ]; then
        echo "Usage: dev task send <repo> <slug> <role> <message>"
        exit 1
    fi

    local session_path
    session_path=$(task_role_session_path "$repo" "$slug" "$role")
    if role_is_pi "$role"; then
        send_pi "$session_path" "$message"
    else
        send_keys "$session_path" "$message" Enter
    fi
}

task_review() {
    local repo="$1"
    local slug="$2"

    if [ -z "$repo" ] || [ -z "$slug" ]; then
        echo "Usage: dev task review <repo> <slug>"
        exit 1
    fi

    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    if [ ! -f "$meta_file" ]; then
        echo "Task not found: $repo/$slug"
        exit 1
    fi

    task_status "$repo" "$slug"
    echo ""
    echo "Slice checkpoints:"
    local slice_id
    while IFS= read -r slice_id; do
        [ -n "$slice_id" ] || continue
        local slice_meta slice_status round
        slice_meta=$(task_slice_meta_file "$repo" "$slug" "$slice_id")
        slice_status=$(jq -r '.status // "unknown"' "$slice_meta" 2>/dev/null)
        round=$(jq -r '.currentRound // 1' "$slice_meta" 2>/dev/null)
        echo "  - $slice_id: $slice_status (currentRound=$(task_slice_round_name "$round"))"
    done < <(task_slice_list "$repo" "$slug")
    echo ""
    echo "Role session review:"
    local role
    for role in plan-owner-codex plan-review-codex plan-critic-claude implementer-codex implementation-review-codex implementation-critic-claude; do
        local session_path
        session_path=$(task_role_session_path "$repo" "$slug" "$role")
        local session_name
        session_name=$(to_session_name "$session_path")
        local backend
        backend=$(session_backend "$session_name")
        if [ -z "$backend" ]; then
            echo "  - $role: not started"
            continue
        fi
        echo "  - $role: $session_path"
        if role_is_pi "$role"; then
            pi_status "$session_path" --messages 1
        else
            local session_name
            session_name=$(to_session_name "$session_path")
            local pane_cmd
            pane_cmd=$(tmux display-message -t "$session_name" -p '#{pane_current_command}' 2>/dev/null || echo "not-running")
            echo "    backend: claude/tmux"
            echo "    pane: $pane_cmd"
        fi
        echo ""
    done
}

task_poll() {
    local repo="$1"
    local slug="$2"

    if [ -z "$repo" ] || [ -z "$slug" ]; then
        echo "Usage: dev task poll <repo> <slug>"
        exit 1
    fi

    echo "Task poll: $repo/$slug"
    local role
    for role in plan-owner-codex plan-review-codex plan-critic-claude implementer-codex implementation-review-codex implementation-critic-claude; do
        local session_path
        session_path=$(task_role_session_path "$repo" "$slug" "$role")
        local session_name
        session_name=$(to_session_name "$session_path")
        local backend
        backend=$(session_backend "$session_name")
        if [ -z "$backend" ]; then
            echo "  - $role: not started"
            continue
        fi
        echo "  - $role:"
        if role_is_pi "$role"; then
            pi_status "$session_path" --messages 1
        else
            local pane_cmd
            pane_cmd=$(tmux display-message -t "$session_name" -p '#{pane_current_command}' 2>/dev/null || echo "not-running")
            echo "    session: $session_path"
            echo "    pane: $pane_cmd"
        fi
    done
}

task_nudge() {
    local repo="$1"
    local slug="$2"
    local role="$3"
    shift 3
    local message="$*"

    if [ -z "$repo" ] || [ -z "$slug" ] || [ -z "$role" ] || [ -z "$message" ]; then
        echo "Usage: dev task nudge <repo> <slug> <role> <message>"
        exit 1
    fi

    echo "Last status before nudge:"
    if role_is_pi "$role"; then
        pi_status "$(task_role_session_path "$repo" "$slug" "$role")" --messages 1
    else
        local session_path
        local session_name
        session_path=$(task_role_session_path "$repo" "$slug" "$role")
        session_name=$(to_session_name "$session_path")
        local pane_cmd
        pane_cmd=$(tmux display-message -t "$session_name" -p '#{pane_current_command}' 2>/dev/null || echo "not-running")
        echo "  role: $role"
        echo "  session: $session_path"
        echo "  pane: $pane_cmd"
    fi
    echo ""
    task_send "$repo" "$slug" "$role" "$message"
}

task_extract_verification_commands() {
    local file="$1"
    awk '
        BEGIN { in_block = 0 }
        /^```(bash|sh)?[[:space:]]*$/ { if (in_block == 0) { in_block = 1; next } else { in_block = 0; next } }
        in_block == 1 { print }
    ' "$file"
}

task_slice_extract_verification_commands() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"
    task_extract_verification_commands "$(task_slice_dir "$repo" "$slug" "$slice_id")/verification.md"
}

task_slice_has_verified_findings() {
    local file="$1"
    if [ ! -f "$file" ]; then
        return 1
    fi

    local verified
    verified=$(grep -Ei '^\s*-\s*\[(confirmed|rejected|partially_applied)\]' "$file" | \
        grep -Evi 'Describe a finding you independently verified and how you addressed it\.|Describe a finding you checked and rejected, with rationale\.|Describe any finding you applied only in part, with rationale\.' || true)
    [ -n "$verified" ]
}

task_slice_validation_failures_json() {
    if [ $# -eq 0 ]; then
        echo "[]"
        return
    fi
    printf '%s\n' "$@" | jq -R . | jq -s '.'
}

task_slice_scope_entries() {
    local file="$1"
    task_section_body "$file" "Scope / Files" | \
        sed -E 's/^[[:space:]]*[-*][[:space:]]*//' | \
        sed -E 's/^[[:space:]]+|[[:space:]]+$//g' | \
        sed -E '/^[[:space:]]*$/d'
}

task_slice_file_in_scope() {
    local changed_file="$1"
    shift
    local scope
    for scope in "$@"; do
        [ -n "$scope" ] || continue
        if [ "$scope" = "." ] || [ "$scope" = "*" ]; then
            return 0
        fi
        case "$changed_file" in
            "$scope"|"$scope"/*)
                return 0
                ;;
        esac
    done
    return 1
}

task_target_git_dir() {
    local repo="$1"
    local slug="$2"
    local target_dir
    target_dir=$(task_target_dir "$repo" "$slug" "implementer-codex")
    if [ -z "$target_dir" ]; then
        target_dir=$(repo_base_dir "$repo")
    fi
    echo "$target_dir"
}

task_git_main_ref() {
    local target_dir="$1"
    if git -C "$target_dir" rev-parse --verify main >/dev/null 2>&1; then
        echo "main"
        return
    fi
    if git -C "$target_dir" rev-parse --verify origin/main >/dev/null 2>&1; then
        echo "origin/main"
        return
    fi
    echo ""
}

task_slice_verify_commit_against_git() {
    local repo="$1"
    local slug="$2"
    local slice_id="$3"
    local commit_ref="$4"

    local target_dir
    target_dir=$(task_target_git_dir "$repo" "$slug")
    if [ ! -d "$target_dir" ]; then
        echo "missing_target_dir:$target_dir"
        return 1
    fi

    if ! git -C "$target_dir" rev-parse --verify "${commit_ref}^{commit}" >/dev/null 2>&1; then
        echo "missing_commit:$commit_ref"
        return 1
    fi

    if ! git -C "$target_dir" merge-base --is-ancestor "$commit_ref" HEAD >/dev/null 2>&1; then
        echo "commit_not_on_current_head:$commit_ref"
        return 1
    fi

    local main_ref
    main_ref=$(task_git_main_ref "$target_dir")
    if [ -n "$main_ref" ] && git -C "$target_dir" merge-base --is-ancestor "$commit_ref" "$main_ref" >/dev/null 2>&1; then
        echo "commit_not_new_relative_to_$main_ref:$commit_ref"
        return 1
    fi

    local slice_file
    slice_file="$(task_slice_dir "$repo" "$slug" "$slice_id")/slice.md"
    local scopes=()
    local scope_entry
    while IFS= read -r scope_entry; do
        [ -n "$scope_entry" ] || continue
        scopes+=("$scope_entry")
    done < <(task_slice_scope_entries "$slice_file")
    if [ ${#scopes[@]} -eq 0 ]; then
        echo "missing_scope_entries:slice.md"
        return 1
    fi

    local changed_file
    while IFS= read -r changed_file; do
        [ -n "$changed_file" ] || continue
        if ! task_slice_file_in_scope "$changed_file" "${scopes[@]}"; then
            echo "out_of_scope_commit_file:$changed_file"
            return 1
        fi
    done < <(git -C "$target_dir" diff-tree --no-commit-id --name-only -r "$commit_ref")

    return 0
}

task_git_worktree_clean() {
    local target_dir="$1"
    [ -d "$target_dir" ] || return 1
    [ -z "$(task_git_changed_files "$target_dir")" ]
}

task_git_changed_files() {
    local target_dir="$1"
    git -C "$target_dir" status --porcelain | while IFS= read -r line; do
        [ -n "$line" ] || continue
        if [[ "$line" =~ ^\?\?[[:space:]]+ ]]; then
            echo "${line#?? }"
        else
            echo "${line:3}"
        fi
    done | sed '/^[[:space:]]*$/d' | grep -Ev '^\.cashew(/|$)' || true
}

task_verify() {
    local repo="$1"
    local slug="$2"

    if [ -z "$repo" ] || [ -z "$slug" ]; then
        echo "Usage: dev task verify <repo> <slug>"
        exit 1
    fi

    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    if [ ! -f "$meta_file" ]; then
        echo "Task not found: $repo/$slug"
        exit 1
    fi

    local dir
    dir=$(task_dir "$repo" "$slug")
    local verify_file="$dir/verification-contract.md"
    if [ ! -f "$verify_file" ]; then
        echo "Verification contract not found: $verify_file"
        exit 1
    fi

    local target_dir
    target_dir=$(task_target_dir "$repo" "$slug" "implementer-codex")
    if [ -z "$target_dir" ]; then
        target_dir=$(repo_base_dir "$repo")
    fi

    local commands
    commands=$(task_extract_verification_commands "$verify_file")
    if [ -z "$commands" ]; then
        echo "No fenced bash/sh commands found in $verify_file"
        exit 1
    fi

    local failures=()
    local executed=()
    local cmd
    while IFS= read -r cmd; do
        [ -z "$cmd" ] && continue
        [[ "$cmd" =~ ^[[:space:]]*# ]] && continue
        executed+=("$cmd")
        echo "Running: $cmd"
        if ! (cd "$target_dir" && bash -lc "$cmd"); then
            failures+=("$cmd")
        fi
    done <<< "$commands"

    local executed_json failures_json
    executed_json=$(printf '%s\n' "${executed[@]}" | jq -R . | jq -s '.')
    if [ ${#failures[@]} -gt 0 ]; then
        failures_json=$(printf '%s\n' "${failures[@]}" | jq -R . | jq -s '.')
    else
        failures_json='[]'
    fi

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local tmp
    tmp=$(mktemp)
    jq \
        --arg now "$now" \
        --arg targetDir "$target_dir" \
        --argjson executed "$executed_json" \
        --argjson failures "$failures_json" \
        '
        .verification.lastRun = {
          at: $now,
          targetDir: $targetDir,
          commands: $executed,
          failures: $failures,
          success: (($failures | length) == 0)
        }
        ' \
        "$meta_file" > "$tmp" && mv "$tmp" "$meta_file"

    if [ ${#failures[@]} -eq 0 ]; then
        echo "Verification passed: $repo/$slug"
        return 0
    fi

    echo "Verification failed: $repo/$slug"
    printf '  - %s\n' "${failures[@]}"
    return 1
}

start_or_attach_command_session() {
    local session_path="$1"
    local target_dir="$2"
    local command_line="$3"

    local session_name
    session_name=$(to_session_name "$session_path")
    local display_name
    display_name=$(to_display_name "$session_name")

    if [ ! -d "$target_dir" ]; then
        echo "Directory not found: $target_dir"
        exit 1
    fi

    cd "$target_dir"
    echo -e "Directory: ${CYAN}$target_dir${RESET}"
    echo -e "Session: ${GREEN}$display_name${RESET}"

    local backend
    backend=$(session_backend "$session_name")

    local can_attach=0
    if [ -t 0 ] && [ -t 1 ]; then
        can_attach=1
    fi

    if [ "$backend" = "tmux" ]; then
        local pane_cmd
        pane_cmd=$(tmux display-message -t "$session_name" -p '#{pane_current_command}' 2>/dev/null || true)
        if [[ "$pane_cmd" == "zsh" || "$pane_cmd" == "bash" || "$pane_cmd" == "sh" || "$pane_cmd" == "fish" ]]; then
            echo -e "${YELLOW}Agent not running — restarting...${RESET}"
            tmux send-keys -t "$session_name" "$command_line" C-m
        fi
        if [ "$can_attach" -eq 1 ]; then
            tmux attach -t "$session_name"
        else
            echo -e "${GREEN}Running:${RESET} $display_name (detached)"
            echo -e "Attach with: ${CYAN}dev $display_name${RESET}"
        fi
        return
    fi

    tmux new-session -d -s "$session_name" -c "$target_dir"
    tmux send-keys -t "$session_name" "$command_line" C-m
    echo -e "${GREEN}Started:${RESET} $display_name (detached)"
    echo -e "Attach with: ${CYAN}dev $display_name${RESET}"
}

task_role_open() {
    local repo="$1"
    local slug="$2"
    local role="${3:-plan-owner-codex}"

    if [ -z "$repo" ] || [ -z "$slug" ] || [ -z "$role" ]; then
        echo "Usage: dev task open <repo> <slug> [role]"
        exit 1
    fi

    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    if [ ! -f "$meta_file" ]; then
        echo "Task not found: $repo/$slug"
        exit 1
    fi

    local target_dir
    target_dir=$(task_target_dir "$repo" "$slug" "$role")
    if [ -z "$target_dir" ]; then
        echo "Role $role requires a worktree. Run: dev task start-impl $repo $slug"
        exit 1
    fi

    local worktree
    worktree=$(jq -r '.worktree // empty' "$meta_file" 2>/dev/null)
    local session_path
    if [[ "$role" == implementer-codex || "$role" == implementation-review-codex || "$role" == implementation-critic-claude ]]; then
        session_path=$(task_session_path "$repo" "$slug" "$role" "$worktree")
    else
        session_path=$(task_session_path "$repo" "$slug" "$role")
    fi

    local session_dir
    session_dir=$(task_session_dir "$repo" "$slug" "$role")
    mkdir -p "$session_dir"

    local command_line
    command_line=$(role_default_command "$role" "$session_dir") || {
        echo "Unknown task role: $role"
        exit 1
    }

    start_or_attach_command_session "$session_path" "$target_dir" "$command_line"
}

task_new() {
    local repo="$1"
    local slug="$2"

    if [ -z "$repo" ] || [ -z "$slug" ]; then
        echo "Usage: dev task new <repo> <slug>"
        exit 1
    fi

    local base_dir
    base_dir=$(repo_base_dir "$repo")
    if [ ! -d "$base_dir" ]; then
        echo "Repo not found: $repo"
        exit 1
    fi

    local dir
    dir=$(task_dir "$repo" "$slug")
    if [ -d "$dir" ]; then
        echo "Task already exists: $dir"
        exit 1
    fi

    mkdir -p "$dir/$TASK_SESSION_DIR_NAME" "$dir/$TASK_SLICE_DIR_NAME"

    cat > "$dir/task.json" <<EOF
{
  "slug": "$slug",
  "repo": "$repo",
  "status": "plan_draft",
  "planLocked": false,
  "worktree": null,
  "createdAt": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "approvals": {
    "plan": {
      "plan-review-codex": null,
      "plan-critic-claude": null
    },
    "implementation": {
      "implementation-review-codex": null,
      "implementation-critic-claude": null
    }
  },
  "validation": {
    "plan": {
      "passed": false,
      "lastRunAt": null,
      "failures": []
    },
    "implementation": {
      "passed": false,
      "lastRunAt": null,
      "failures": []
    }
  },
  "verification": {
    "lastRun": {
      "at": null,
      "targetDir": null,
      "commands": [],
      "failures": [],
      "success": false
    }
  }
}
EOF

    cat > "$dir/proposal.md" <<'EOF'
# Proposal

## Goal

## Why

## Constraints

## Open Questions
EOF

    cat > "$dir/plan.md" <<'EOF'
# Plan

## Goal

## Commit Slices

Define every commit slice up front. For non-trivial work, use multiple slices. The plan is not lockable until slices exist under `.cashew/tasks/<slug>/slices/`.

## Non-Goals

## Constraints

## Affected Files / Systems

## Risks

## Acceptance Criteria

## Tests

## Rollout / Rollback

## Open Questions
EOF

    cat > "$dir/plan-review-codex.md" <<'EOF'
# Codex Plan Review

Use `plan-review-codex.state.json` for the authoritative structured review state.

## Narrative Review

Summarize reasoning, evidence, tradeoffs, and any context around the findings recorded in the state file.
EOF

    cat > "$dir/plan-review-codex.state.json" <<'EOF'
{
  "reviewerRole": "plan-review-codex",
  "decision": "pending",
  "blockingFindings": [],
  "nonBlockingFindings": [],
  "summary": "",
  "updatedAt": null
}
EOF

    cat > "$dir/plan-review-claude.md" <<'EOF'
# Claude Plan Critique

Use `plan-review-claude.state.json` for the authoritative structured review state.

## Narrative Review

Summarize reasoning, evidence, tradeoffs, and any context around the findings recorded in the state file.
EOF

    cat > "$dir/plan-review-claude.state.json" <<'EOF'
{
  "reviewerRole": "plan-critic-claude",
  "decision": "pending",
  "blockingFindings": [],
  "nonBlockingFindings": [],
  "summary": "",
  "updatedAt": null
}
EOF

    cat > "$dir/plan-open-issues.md" <<'EOF'
# Plan Open Issues

Track open blockers and their resolution here.
EOF

    cat > "$dir/implementation-notes.md" <<'EOF'
# Implementation Notes

Track implementation deltas against the locked plan here.
EOF

    cat > "$dir/implementation-review-codex.md" <<'EOF'
# Codex Implementation Review

Use `implementation-review-codex.state.json` for the authoritative structured review state.

## Narrative Review

Summarize reasoning, evidence, tradeoffs, and any context around the findings recorded in the state file.
EOF

    cat > "$dir/implementation-review-codex.state.json" <<'EOF'
{
  "reviewerRole": "implementation-review-codex",
  "decision": "pending",
  "blockingFindings": [],
  "nonBlockingFindings": [],
  "summary": "",
  "updatedAt": null
}
EOF

    cat > "$dir/implementation-review-claude.md" <<'EOF'
# Claude Implementation Audit

Use `implementation-review-claude.state.json` for the authoritative structured review state.

## Narrative Review

Summarize reasoning, evidence, tradeoffs, and any context around the findings recorded in the state file.
EOF

    cat > "$dir/implementation-review-claude.state.json" <<'EOF'
{
  "reviewerRole": "implementation-critic-claude",
  "decision": "pending",
  "blockingFindings": [],
  "nonBlockingFindings": [],
  "summary": "",
  "updatedAt": null
}
EOF

    cat > "$dir/verification-contract.md" <<'EOF'
# Verification Contract

Document the target repo's required lint, typecheck, unit, integration, DB integration, live API, build, and migration checks here before implementation.
EOF

    echo -e "${GREEN}Task created:${RESET} $repo/$slug"
    echo "Files:"
    echo "  $dir/proposal.md"
    echo "  $dir/plan.md"
    echo "  $dir/plan-review-codex.md"
    echo "  $dir/plan-review-claude.md"
    echo "  $dir/slices/"
    echo ""
    echo "Next:"
    echo "  dev task open $repo $slug plan-owner-codex"
    echo "  dev task open $repo $slug plan-review-codex"
    echo "  dev task open $repo $slug plan-critic-claude"
    echo "  dev task slice new $repo $slug slice-01"
}

task_status() {
    local repo="$1"
    local slug="$2"

    if [ -z "$repo" ] || [ -z "$slug" ]; then
        echo "Usage: dev task status <repo> <slug>"
        exit 1
    fi

    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    if [ ! -f "$meta_file" ]; then
        echo "Task not found: $repo/$slug"
        exit 1
    fi

    local dir
    dir=$(task_dir "$repo" "$slug")
    local status
    local locked
    local worktree
    local plan_validation
    local impl_validation
    local plan_codex
    local plan_claude
    local impl_codex
    local impl_claude
    local verify_ok
    local verify_at
    local slice_count
    status=$(jq -r '.status // "unknown"' "$meta_file" 2>/dev/null)
    locked=$(jq -r '.planLocked // false' "$meta_file" 2>/dev/null)
    worktree=$(jq -r '.worktree // empty' "$meta_file" 2>/dev/null)
    plan_validation=$(jq -r '.validation.plan.passed // false' "$meta_file" 2>/dev/null)
    impl_validation=$(jq -r '.validation.implementation.passed // false' "$meta_file" 2>/dev/null)
    plan_codex=$(jq -r '.approvals.plan["plan-review-codex"].decision // "pending"' "$meta_file" 2>/dev/null)
    plan_claude=$(jq -r '.approvals.plan["plan-critic-claude"].decision // "pending"' "$meta_file" 2>/dev/null)
    impl_codex=$(jq -r '.approvals.implementation["implementation-review-codex"].decision // "pending"' "$meta_file" 2>/dev/null)
    impl_claude=$(jq -r '.approvals.implementation["implementation-critic-claude"].decision // "pending"' "$meta_file" 2>/dev/null)
    verify_ok=$(jq -r '.verification.lastRun.success // false' "$meta_file" 2>/dev/null)
    verify_at=$(jq -r '.verification.lastRun.at // empty' "$meta_file" 2>/dev/null)
    slice_count=$(task_slice_count "$repo" "$slug")

    echo -e "${BOLD}Task:${RESET} $repo/$slug"
    echo -e "${DIM}Dir:${RESET} $dir"
    echo -e "${DIM}Status:${RESET} $status"
    echo -e "${DIM}Plan locked:${RESET} $locked"
    if [ -n "$worktree" ]; then
        echo -e "${DIM}Worktree:${RESET} $worktree"
    fi
    echo -e "${DIM}Commit slices:${RESET} $slice_count"
    echo ""
    echo "Approvals:"
    echo "  plan-review-codex: $plan_codex"
    echo "  plan-critic-claude: $plan_claude"
    echo "  implementation-review-codex: $impl_codex"
    echo "  implementation-critic-claude: $impl_claude"
    echo ""
    echo "Validation:"
    echo "  plan: $plan_validation"
    jq -r '.validation.plan.failures[]? // empty' "$meta_file" 2>/dev/null | sed 's/^/    - /'
    echo "  implementation: $impl_validation"
    jq -r '.validation.implementation.failures[]? // empty' "$meta_file" 2>/dev/null | sed 's/^/    - /'
    echo ""
    echo "Verification:"
    echo "  success: $verify_ok"
    if [ -n "$verify_at" ]; then
        echo "  last run: $verify_at"
    fi
    jq -r '.verification.lastRun.failures[]? // empty' "$meta_file" 2>/dev/null | sed 's/^/    - /'
    echo ""
    local locked_plan_hash
    local current_plan_hash
    locked_plan_hash=$(jq -r '.lock.planHash // empty' "$meta_file" 2>/dev/null)
    current_plan_hash=$(task_hash_file "$dir/plan.md")
    echo "Plan lock:"
    if [ -n "$locked_plan_hash" ]; then
        if [ "$locked_plan_hash" = "$current_plan_hash" ]; then
            echo "  drift: false"
        else
            echo "  drift: true"
        fi
    else
        echo "  drift: n/a"
    fi
    echo ""
    echo "Slices:"
    if [ "$slice_count" -gt 0 ]; then
        local slice_id
        while IFS= read -r slice_id; do
            [ -n "$slice_id" ] || continue
            local slice_meta slice_status slice_approved slice_commit
            slice_meta=$(task_slice_meta_file "$repo" "$slug" "$slice_id")
            slice_status=$(jq -r '.status // "unknown"' "$slice_meta" 2>/dev/null)
            slice_approved=$(jq -r '.approvedToCommit // false' "$slice_meta" 2>/dev/null)
            slice_commit=$(jq -r '.commit // empty' "$slice_meta" 2>/dev/null)
            if [ -n "$slice_commit" ]; then
                echo "  - $slice_id [$slice_status, approved=$slice_approved, commit=$slice_commit]"
            else
                echo "  - $slice_id [$slice_status, approved=$slice_approved]"
            fi
        done < <(task_slice_list "$repo" "$slug")
    else
        echo "  - none declared"
    fi
    echo ""
    echo "Next actions:"
    task_next_actions "$repo" "$slug" | sed 's/^/  - /'
    echo ""
    echo "Artifacts:"
    for f in proposal.md plan.md plan-review-codex.md plan-review-codex.state.json plan-review-claude.md plan-review-claude.state.json implementation-notes.md implementation-review-codex.md implementation-review-codex.state.json implementation-review-claude.md implementation-review-claude.state.json verification-contract.md; do
        if [ -f "$dir/$f" ]; then
            echo "  - $f"
        fi
    done
    if [ -d "$dir/$TASK_SLICE_DIR_NAME" ]; then
        echo "  - $TASK_SLICE_DIR_NAME/"
    fi
}

task_lock_plan() {
    local repo="$1"
    local slug="$2"

    if [ -z "$repo" ] || [ -z "$slug" ]; then
        echo "Usage: dev task lock-plan <repo> <slug>"
        exit 1
    fi

    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    if [ ! -f "$meta_file" ]; then
        echo "Task not found: $repo/$slug"
        exit 1
    fi

    task_validate_phase "$repo" "$slug" plan || exit 1
    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local plan_hash
    plan_hash=$(task_hash_file "$(task_dir "$repo" "$slug")/plan.md")
    local tmp
    tmp=$(mktemp)
    jq \
        --arg now "$now" \
        --arg planHash "$plan_hash" \
        '
        .planLocked = true
        | .status = "plan_locked"
        | .lock = {
            lockedAt: $now,
            planHash: $planHash
          }
        ' \
        "$meta_file" > "$tmp" && mv "$tmp" "$meta_file"
    echo "Plan locked: $repo/$slug"
}

task_start_impl() {
    local repo="$1"
    local slug="$2"
    local branch="${3:-$slug}"

    if [ -z "$repo" ] || [ -z "$slug" ]; then
        echo "Usage: dev task start-impl <repo> <slug> [worktree]"
        exit 1
    fi

    local meta_file
    meta_file=$(task_meta_file "$repo" "$slug")
    if [ ! -f "$meta_file" ]; then
        echo "Task not found: $repo/$slug"
        exit 1
    fi

    local locked
    locked=$(jq -r '.planLocked // false' "$meta_file" 2>/dev/null)
    if [ "$locked" != "true" ]; then
        echo "Plan is not locked for $repo/$slug"
        echo "Run: dev task lock-plan $repo $slug"
        exit 1
    fi

    local repo_dir="$PROJECTS_DIR/$repo"
    if [ -d "$repo_dir/.bare" ] && [ ! -d "$repo_dir/$branch" ]; then
        add_worktree "$repo" "$branch"
    fi

    local tmp
    tmp=$(mktemp)
    jq --arg worktree "$branch" '.worktree = $worktree | .status = "implementation_in_progress"' "$meta_file" > "$tmp" && mv "$tmp" "$meta_file"

    echo "Implementation worktree ready: $repo/$branch"
    task_role_open "$repo" "$slug" "implementer-codex"
}

KW_META_DIR="$HOME/.pi/kw"

kw_safe() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's|[^a-z0-9._-]|-|g'
}

kw_meta_file() {
    local repo="$1"
    local name="$2"
    echo "$KW_META_DIR/$(kw_safe "$repo")__$(kw_safe "$name").json"
}

kw_meta_get() {
    local repo="$1"
    local name="$2"
    local field="$3"
    local file
    file=$(kw_meta_file "$repo" "$name")
    if [ ! -f "$file" ]; then
        echo ""
        return
    fi
    jq -r ".${field} // empty" "$file" 2>/dev/null
}

kw_tags_json() {
    local tags_csv="$1"
    local cleaned
    cleaned=$(echo "$tags_csv" | tr ',' '\n' | sed 's/^ *//;s/ *$//' | sed '/^$/d')
    if [ -z "$cleaned" ]; then
        echo "[]"
        return
    fi
    echo "$cleaned" | jq -R . | jq -s '.'
}

kw_write_meta() {
    local repo="$1"
    local name="$2"
    local tags_csv="$3"
    local description="$4"
    local session_dir="$5"
    local queue_file="$6"
    local status_file="$7"
    local session_path="$8"

    local file
    file=$(kw_meta_file "$repo" "$name")
    mkdir -p "$KW_META_DIR"

    local created_at
    local updated_at
    created_at=$(kw_meta_get "$repo" "$name" "createdAt")
    if [ -z "$created_at" ]; then
        created_at=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    fi
    updated_at=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    if [ -z "$description" ]; then
        description=$(kw_meta_get "$repo" "$name" "description")
    fi
    if [ -z "$session_dir" ]; then
        session_dir=$(kw_meta_get "$repo" "$name" "sessionDir")
    fi
    if [ -z "$queue_file" ]; then
        queue_file=$(kw_meta_get "$repo" "$name" "queueFile")
    fi
    if [ -z "$status_file" ]; then
        status_file=$(kw_meta_get "$repo" "$name" "statusFile")
    fi
    if [ -z "$session_path" ]; then
        session_path=$(kw_meta_get "$repo" "$name" "sessionPath")
    fi

    local tags_json
    if [ -n "$tags_csv" ]; then
        tags_json=$(kw_tags_json "$tags_csv")
    else
        tags_json=$(jq -c '.tags // []' "$file" 2>/dev/null || echo "[]")
    fi

    jq -n \
        --arg repo "$repo" \
        --arg name "$name" \
        --arg description "$description" \
        --arg createdAt "$created_at" \
        --arg updatedAt "$updated_at" \
        --arg sessionDir "$session_dir" \
        --arg queueFile "$queue_file" \
        --arg statusFile "$status_file" \
        --arg sessionPath "$session_path" \
        --arg role "knowledge-worker" \
        --argjson tags "$tags_json" \
        '{repo: $repo, name: $name, role: $role, tags: $tags, description: $description, createdAt: $createdAt, updatedAt: $updatedAt, sessionDir: $sessionDir, queueFile: $queueFile, statusFile: $statusFile, sessionPath: $sessionPath}' \
        > "$file"
}

kw_queue_file() {
    local repo="$1"
    local name="$2"
    local safe_id
    safe_id="$(kw_safe "$repo")__$(kw_safe "$name")"
    echo "$HOME/.pi/queues/kw-${safe_id}.jsonl"
}

kw_status_file() {
    local repo="$1"
    local name="$2"
    local safe_id
    safe_id="$(kw_safe "$repo")__$(kw_safe "$name")"
    echo "$HOME/.pi/status/kw-${safe_id}.jsonl"
}

kw_session_dir() {
    local repo="$1"
    local name="$2"
    local safe_id
    safe_id="$(kw_safe "$repo")__$(kw_safe "$name")"
    echo "$HOME/.pi/agent/kw-sessions/kw-${safe_id}"
}

get_tmux_sessions() {
    if ! command -v tmux >/dev/null 2>&1; then
        return 0
    fi

    tmux list-sessions -F "#S" 2>/dev/null | grep -v "^$" || true
}

get_all_sessions() {
    get_tmux_sessions
}

session_backend() {
    local name="$1"

    if command -v tmux >/dev/null 2>&1; then
        if tmux has-session -t "$name" 2>/dev/null; then
            echo "tmux"
            return 0
        fi
    fi

    echo ""
    return 1
}

# Get Pi agent status indicator for a working directory.
# Returns a colored status tag or empty string if no Pi status exists.
pi_status_tag() {
    local cwd="$1"
    local safe_path
    safe_path=$(echo "$cwd" | tr '[:upper:]' '[:lower:]' | tr '/' '-' | sed 's/^-//')

    local status_file="$HOME/.pi/status/${safe_path}.jsonl"
    local queue_file="$HOME/.pi/queues/${safe_path}.jsonl"

    # No status file = no Pi info to show
    [ -f "$status_file" ] || return

    local last_line
    last_line=$(tail -n 1 "$status_file" 2>/dev/null)
    [ -z "$last_line" ] && return

    # Check if Pi's session file is newer than the status file (agent is mid-turn)
    local session_file
    session_file=$(echo "$last_line" | grep -oE '"sessionFile":"[^"]*"' | sed 's/"sessionFile":"//;s/"$//')
    if [ -n "$session_file" ] && [ -f "$session_file" ]; then
        local status_mtime session_mtime
        if [[ "$(uname)" == "Darwin" ]]; then
            status_mtime=$(stat -f "%m" "$status_file" 2>/dev/null)
            session_mtime=$(stat -f "%m" "$session_file" 2>/dev/null)
        else
            status_mtime=$(stat -c "%Y" "$status_file" 2>/dev/null)
            session_mtime=$(stat -c "%Y" "$session_file" 2>/dev/null)
        fi
        if [ -n "$session_mtime" ] && [ -n "$status_mtime" ] && [ "$session_mtime" -gt "$status_mtime" ]; then
            echo -e " ${GREEN}● working${RESET}"
            return
        fi
    fi

    # Working: agent_start fired, no agent_end yet (requires updated pi-subscribe extension)
    if echo "$last_line" | grep -q '"status":"working"'; then
        echo -e " ${GREEN}● working${RESET}"
        return
    fi

    # Queued: pending messages waiting to be processed
    if [ -f "$queue_file" ] && [ -s "$queue_file" ]; then
        echo -e " ${YELLOW}● queued${RESET}"
        return
    fi

    # Error: last turn had an error AND agent is not actively working
    if echo "$last_line" | grep -q '"errorMessage"' && ! echo "$last_line" | grep -qE '"errorMessage":\s*null'; then
        echo -e " ${RED}⚠ error${RESET}"
        return
    fi

    # Done/idle
    echo -e " ${CYAN}○ idle${RESET}"
}

list_active_sessions() {
    local sessions
    sessions=$(get_all_sessions)

    echo -e "${BOLD}Active sessions:${RESET}"
    if [ -n "$sessions" ]; then
        echo "$sessions" | while read -r line; do
            sess=$(echo "$line" | awk '{print $1}')
            display=$(to_display_name "$sess")
            local tag=""
            local pane_cwd
            pane_cwd=$(tmux display-message -p -t "$sess" '#{pane_current_path}' 2>/dev/null)
            [ -n "$pane_cwd" ] && tag=$(pi_status_tag "$pane_cwd")
            echo -e "  ${YELLOW}→${RESET} $display${tag} ${DIM}[$sess]${RESET}"
        done
    else
        echo -e "  ${DIM}(none)${RESET}"
    fi
}

list_projects() {
    local show_tree="${1:-0}"

    # Get all sessions
    sessions=$(get_all_sessions)

    if [ "$show_tree" -eq 1 ]; then
        echo -e "${BOLD}Projects in $PROJECTS_DIR:${RESET}"
        echo ""

        # Show hub session(s) first
        hub_sessions=$(echo "$sessions" | grep "^hub" || true)
        if [ -n "$hub_sessions" ]; then
            echo -e "  ${GREEN}●${RESET} ${BOLD}hub${RESET} ${DIM}($PROJECTS_DIR root)${RESET}"
            echo "$hub_sessions" | while read -r sess; do
                sess_name=$(echo "$sess" | awk '{print $1}')
                local tag
                tag=$(pi_status_tag "$PROJECTS_DIR")
                if [[ "$sess_name" == "hub" ]]; then
                    echo -e "      └─ main${tag} ${DIM}(dev hub)${RESET}"
                else
                    sub="${sess_name#hub${SEP}}"
                    echo -e "      └─ ${sub}${tag} ${DIM}(dev hub/$sub)${RESET}"
                fi
            done
        else
            echo -e "  ${DIM}○${RESET} hub ${DIM}(dev hub to start)${RESET}"
        fi
        echo ""

        for dir in "$PROJECTS_DIR"/*/; do
            [ -d "$dir" ] || continue
            project=$(basename "$dir")
            [[ "$project" == "dev" ]] && continue

            # Check if this is a worktree-based repo
            if [ -d "$dir/.bare" ]; then
                echo -e "  ${MAGENTA}◆${RESET} ${BOLD}$project${RESET} ${DIM}(worktrees)${RESET}"

                # List worktrees
                for wt_dir in "$dir"/*/; do
                    [ -d "$wt_dir" ] || continue
                    wt=$(basename "$wt_dir")
                    [[ "$wt" == ".bare" ]] && continue

                    # Check for sessions (using -- separator)
                    session_prefix="${project}${SEP}${wt}"
                    wt_sessions=$(echo "$sessions" | grep -E "^${session_prefix}($|${SEP})" || true)
                    if [ -n "$wt_sessions" ]; then
                        echo -e "      ${GREEN}●${RESET} ${CYAN}$wt${RESET}"
                        echo "$wt_sessions" | while read -r sess; do
                            sess_name=$(echo "$sess" | awk '{print $1}')
                            display=$(to_display_name "$sess_name")
                            local tag
                            tag=$(pi_status_tag "$wt_dir")
                            if [[ "$sess_name" == "$session_prefix" ]]; then
                                echo -e "          └─ main${tag} ${DIM}(dev $project/$wt)${RESET}"
                            else
                                sub="${sess_name#${session_prefix}${SEP}}"
                                echo -e "          └─ ${sub}${tag} ${DIM}(dev $project/$wt/$sub)${RESET}"
                            fi
                        done
                    else
                        echo -e "      ${DIM}○${RESET} ${DIM}$wt${RESET}"
                    fi
                done
                list_repo_tasks "$project"
            else
                # Regular repo
                session_prefix="${project}"
                project_sessions=$(echo "$sessions" | grep -E "^${session_prefix}($|${SEP})" || true)
                if [ -n "$project_sessions" ]; then
                    echo -e "  ${GREEN}●${RESET} ${BOLD}$project${RESET}"
                    echo "$project_sessions" | while read -r sess; do
                        sess_name=$(echo "$sess" | awk '{print $1}')
                        local tag
                        tag=$(pi_status_tag "$dir")
                        if [[ "$sess_name" == "$project" ]]; then
                            echo -e "      └─ main${tag} ${DIM}(dev $project)${RESET}"
                        else
                            sub="${sess_name#${project}${SEP}}"
                            echo -e "      └─ ${sub}${tag} ${DIM}(dev $project/$sub)${RESET}"
                        fi
                    done
                else
                    echo -e "  ${DIM}○${RESET} $project"
                fi
                list_repo_tasks "$project"
            fi
        done

        echo ""
    fi

    list_active_sessions

    echo ""
    echo -e "${DIM}Usage: dev hub | dev <repo>[/<worktree>][/<sub>] | dev new <repo> <url>${RESET}"
    if [ "$show_tree" -eq 0 ]; then
        echo -e "${DIM}Tip: dev ls --full to show full project tree${RESET}"
    fi
}

attach_session() {
    local input="$1"

    # Parse input: repo/worktree/sub or repo/sub or repo
    IFS='/' read -ra parts <<< "$input"

    local repo="${parts[0]}"
    local worktree=""
    local sub=""
    local session_name=""
    local target_dir=""

    local repo_dir="$PROJECTS_DIR/$repo"

    if [ ! -d "$repo_dir" ]; then
        echo "Project not found: $repo_dir"
        echo "Create it with: dev new $repo <git-url>"
        exit 1
    fi

    # Determine if worktree repo
    if [ -d "$repo_dir/.bare" ]; then
        # Worktree-based repo
        if [ ${#parts[@]} -ge 2 ]; then
            worktree="${parts[1]}"
            target_dir="$repo_dir/$worktree"

            if [ ! -d "$target_dir" ]; then
                echo "Worktree not found: $worktree"
                echo "Available worktrees:"
                for d in "$repo_dir"/*/; do
                    [ "$(basename "$d")" != ".bare" ] && echo "  - $(basename "$d")"
                done
                echo ""
                echo "Create with: dev wt $repo <branch>"
                exit 1
            fi

            session_name="${repo}${SEP}${worktree}"

            if [ ${#parts[@]} -ge 3 ]; then
                sub="${parts[2]}"
                session_name="${repo}${SEP}${worktree}${SEP}${sub}"
            fi
        else
            # Default to 'main' worktree if exists
            if [ -d "$repo_dir/main" ]; then
                worktree="main"
                target_dir="$repo_dir/main"
                session_name="${repo}${SEP}main"
            else
                # Pick first available worktree
                for d in "$repo_dir"/*/; do
                    if [ "$(basename "$d")" != ".bare" ]; then
                        worktree=$(basename "$d")
                        target_dir="$d"
                        session_name="${repo}${SEP}${worktree}"
                        break
                    fi
                done
            fi
        fi
    else
        # Regular repo
        target_dir="$repo_dir"
        session_name="$repo"

        if [ ${#parts[@]} -ge 2 ]; then
            sub="${parts[1]}"
            session_name="${repo}${SEP}${sub}"
        fi
    fi

    if [ -z "$target_dir" ] || [ ! -d "$target_dir" ]; then
        echo "Could not determine target directory"
        exit 1
    fi

    cd "$target_dir"
    local display_name=$(to_display_name "$session_name")
    echo -e "Directory: ${CYAN}$target_dir${RESET}"
    echo -e "Session: ${GREEN}$display_name${RESET}"

    local auto_command=()
    if [ -n "$sub" ]; then
        case "$sub" in
            pi)
                auto_command=(pi)
                ;;
            claude)
                auto_command=(claude --dangerously-skip-permissions)
                ;;
        esac
    else
        if [ -d "$repo_dir/.bare" ]; then
            auto_command=(pi)
        else
            auto_command=(claude --dangerously-skip-permissions)
        fi
    fi

    local backend
    backend=$(session_backend "$session_name")

    if [ "$backend" = "tmux" ]; then
        # If the agent process has exited (pane is at a shell prompt), restart it
        if [ ${#auto_command[@]} -gt 0 ]; then
            local pane_cmd
            pane_cmd=$(tmux display-message -t "$session_name" -p '#{pane_current_command}' 2>/dev/null || true)
            local agent_name="${auto_command[0]}"
            # Shell means the agent exited — restart it
            if [[ "$pane_cmd" == "zsh" || "$pane_cmd" == "bash" || "$pane_cmd" == "sh" || "$pane_cmd" == "fish" ]]; then
                echo -e "${YELLOW}Agent ($agent_name) not running — restarting...${RESET}"
                local cmd_line="${auto_command[*]}"
                tmux send-keys -t "$session_name" "$cmd_line" C-m
            fi
        fi
        tmux attach -t "$session_name"
        return
    fi

    # If no sub specified on a worktree repo, check for existing pi sub-session
    if [ -z "$sub" ] && [ -d "$repo_dir/.bare" ]; then
        local pi_sub="${session_name}${SEP}pi"
        if [ "$(session_backend "$pi_sub")" = "tmux" ]; then
            # Check if pi agent is still running
            local pane_cmd
            pane_cmd=$(tmux display-message -t "$pi_sub" -p '#{pane_current_command}' 2>/dev/null || true)
            if [[ "$pane_cmd" == "zsh" || "$pane_cmd" == "bash" || "$pane_cmd" == "sh" || "$pane_cmd" == "fish" ]]; then
                echo -e "${YELLOW}Agent (pi) not running — restarting...${RESET}"
                tmux send-keys -t "$pi_sub" "pi" C-m
            fi
            echo -e "Attaching to existing pi sub-session: ${GREEN}$(to_display_name "$pi_sub")${RESET}"
            tmux attach -t "$pi_sub"
            return
        fi
    fi

    # Create new session detached (safe for non-interactive callers)
    tmux new-session -d -s "$session_name" -c "$target_dir"
    if [ ${#auto_command[@]} -gt 0 ]; then
        local cmd_line
        cmd_line="${auto_command[*]}"
        tmux send-keys -t "$session_name" "$cmd_line" C-m
    fi
    echo -e "${GREEN}Started:${RESET} $display_name (detached)"
    echo -e "Attach with: ${CYAN}dev $display_name${RESET}"
}

new_project() {
    local name="$1"
    local url="$2"
    local project_dir="$PROJECTS_DIR/$name"

    if [ -d "$project_dir" ]; then
        echo "Project already exists: $project_dir"
        exit 1
    fi

    if [ -z "$url" ]; then
        echo "Usage: dev new <project-name> <git-url>"
        exit 1
    fi

    echo "Setting up worktree-based repo..."
    mkdir -p "$project_dir"

    # Clone as bare repo
    echo "Cloning bare repo..."
    git clone --bare "$url" "$project_dir/.bare"

    # Configure the bare repo
    cd "$project_dir/.bare"
    git config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
    git fetch origin

    # Create main worktree
    echo "Creating 'main' worktree..."
    cd "$project_dir"

    # Determine default branch
    default_branch=$(git --git-dir=.bare symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo "main")

    git --git-dir=.bare worktree add main "$default_branch"

    echo ""
    echo -e "${GREEN}Project created!${RESET}"
    echo ""
    echo "Structure:"
    echo "  $PROJECTS_DIR/$name/"
    echo "  ├── .bare/     (git data)"
    echo "  └── main/      (default branch worktree)"
    echo ""
    echo "Commands:"
    echo "  dev $name/main/pi            # create or attach pi sub-session"
    echo "  dev $name/main/claude        # claude sub-session"
    echo "  dev wt $name feature-x       # add feature-x worktree (pi starts detached)"
}

init_project() {
    local name="$1"

    if [ -z "$name" ]; then
        echo "Usage: dev init <project-name>"
        exit 1
    fi

    local project_dir="$PROJECTS_DIR/$name"

    if [ -d "$project_dir" ]; then
        echo "Project already exists: $project_dir"
        exit 1
    fi

    echo "Initializing worktree-based repo..."
    mkdir -p "$project_dir/tmp"
    cd "$project_dir/tmp"
    git init -b main --quiet
    echo "# $name" > README.md
    git add README.md
    git commit --quiet -m "initial commit"

    cd "$project_dir"
    git clone --bare tmp/.git .bare --quiet
    rm -rf tmp

    cd .bare
    git remote remove origin 2>/dev/null
    git worktree add ../main main --quiet

    echo ""
    echo -e "${GREEN}Project created!${RESET}"
    echo ""
    echo "Structure:"
    echo "  $PROJECTS_DIR/$name/"
    echo "  ├── .bare/     (git data)"
    echo "  └── main/      (default branch worktree)"
    echo ""
    echo "Commands:"
    echo "  dev $name/main/pi            # create or attach pi sub-session"
    echo "  dev $name/main/claude        # claude sub-session"
    echo "  dev wt $name feature-x       # add feature-x worktree (pi starts detached)"
}

add_worktree() {
    local repo="$1"
    local branch="$2"
    local base="${3:-main}"
    local repo_dir="$PROJECTS_DIR/$repo"

    if [ ! -d "$repo_dir/.bare" ]; then
        echo "Not a worktree-based repo: $repo"
        echo "Use 'dev new $repo <url>' to create one"
        exit 1
    fi

    if [ -z "$branch" ]; then
        echo "Usage: dev wt <repo> <branch> [base-branch]"
        exit 1
    fi

    cd "$repo_dir"

    # Fetch latest when a remote exists
    if git --git-dir=.bare remote get-url origin >/dev/null 2>&1; then
        git --git-dir=.bare fetch origin
    fi

    # Check if branch exists remotely
    if git --git-dir=.bare show-ref --verify --quiet "refs/remotes/origin/$branch"; then
        echo "Creating worktree from existing remote branch: $branch"
        git --git-dir=.bare worktree add "$branch" "$branch"
    else
        echo "Creating new branch '$branch' from '$base'"
        git --git-dir=.bare worktree add -b "$branch" "$branch" "$base"
    fi

    local pi_session="${repo}${SEP}${branch}${SEP}pi"
    local started_pi=0
    if command -v tmux >/dev/null 2>&1 && command -v pi >/dev/null 2>&1; then
        if [ -z "$(session_backend "$pi_session")" ]; then
            tmux new-session -d -s "$pi_session" -c "$repo_dir/$branch"
            tmux send-keys -t "$pi_session" "pi" C-m
            started_pi=1
        fi
    fi

    echo ""
    echo -e "${GREEN}Worktree created!${RESET}"
    if [ "$started_pi" -eq 1 ]; then
        echo -e "  pi started in session: ${CYAN}dev $repo/$branch/pi${RESET} (detached)"
    fi
    echo "  dev $repo/$branch/pi         # attach to pi sub-session"
    echo "  dev $repo/$branch/claude     # claude sub-session"
}

kw_list() {
    local repo_filter="${1:-}"

    if [ ! -d "$KW_META_DIR" ]; then
        echo "No knowledge workers found."
        return
    fi

    local found=0
    for file in "$KW_META_DIR"/*.json; do
        [ -f "$file" ] || continue
        local repo
        local name
        local tags
        local description
        local updated
        local session_path
        repo=$(jq -r '.repo // ""' "$file" 2>/dev/null)
        if [ -n "$repo_filter" ] && [ "$repo_filter" != "$repo" ]; then
            continue
        fi
        name=$(jq -r '.name // ""' "$file" 2>/dev/null)
        tags=$(jq -r '.tags // [] | join(",")' "$file" 2>/dev/null)
        description=$(jq -r '.description // ""' "$file" 2>/dev/null)
        updated=$(jq -r '.updatedAt // ""' "$file" 2>/dev/null)
        session_path=$(jq -r '.sessionPath // empty' "$file" 2>/dev/null)

        if [ -z "$repo" ] || [ -z "$name" ]; then
            continue
        fi

        found=1
        if [ -n "$description" ]; then
            description=$(echo "$description" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g')
        fi
        if [ -z "$session_path" ]; then
            session_path="${repo}/kw-${name}"
        fi
        echo "- ${session_path}  tags: ${tags:-none}  updated: ${updated:-unknown}"
        if [ -n "$description" ]; then
            echo "  note: $description"
        fi
    done

    if [ "$found" -eq 0 ]; then
        echo "No knowledge workers found."
    fi
}

kw_tag() {
    local input="$1"
    shift

    if [ -z "$input" ] || [ $# -eq 0 ]; then
        echo "Usage: dev kw-tags <repo>/<name> <tags>"
        echo ""
        echo "Set tags for a knowledge worker (comma-separated)."
        exit 1
    fi

    local tags_csv="$*"

    IFS='/' read -ra parts <<< "$input"
    local repo="${parts[0]}"
    local name="${parts[1]:-}"
    if [ -z "$repo" ] || [ -z "$name" ]; then
        echo "Usage: dev kw-tags <repo>/<name> <tags>"
        exit 1
    fi

    kw_write_meta "$repo" "$name" "$tags_csv" "" "" "" "" ""
    echo "Updated tags for $repo/kw-$name"
}

kw_note() {
    local input="$1"
    shift

    if [ -z "$input" ] || [ $# -eq 0 ]; then
        echo "Usage: dev kw-note <repo>/<name> <note>"
        echo ""
        echo "Set description/note for a knowledge worker."
        exit 1
    fi

    local note="$*"

    IFS='/' read -ra parts <<< "$input"
    local repo="${parts[0]}"
    local name="${parts[1]:-}"
    if [ -z "$repo" ] || [ -z "$name" ]; then
        echo "Usage: dev kw-note <repo>/<name> <note>"
        exit 1
    fi

    kw_write_meta "$repo" "$name" "" "$note" "" "" "" ""
    echo "Updated note for $repo/kw-$name"
}

kw_session() {
    local repo="$1"
    local name="$2"
    shift 2

    local tags=""
    local description=""
    local bootstrap=""
    local bootstrap_file=""
    local attach=0
    local worktree="main"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --tags)
                tags="${2:-}"
                shift 2
                ;;
            --description|--desc)
                description="${2:-}"
                shift 2
                ;;
            --bootstrap|-b)
                bootstrap="${2:-}"
                shift 2
                ;;
            --bootstrap-file)
                bootstrap_file="${2:-}"
                shift 2
                ;;
            --worktree|-w)
                worktree="${2:-main}"
                shift 2
                ;;
            --attach|-a)
                attach=1
                shift
                ;;
            *)
                echo "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    if [ -z "$repo" ] || [ -z "$name" ]; then
        echo "Usage: dev kw <repo> <name> [--tags <tags>] [--description <text>] [--bootstrap <text>] [--bootstrap-file <file>] [--worktree <name>] [--attach]"
        exit 1
    fi

    local repo_dir="$PROJECTS_DIR/$repo"
    if [ ! -d "$repo_dir" ]; then
        echo "Repo not found: $repo"
        exit 1
    fi

    local target_dir=""
    local session_name=""
    local session_path=""

    if [ -d "$repo_dir/.bare" ]; then
        target_dir="$repo_dir/$worktree"
        if [ ! -d "$target_dir" ]; then
            echo "Worktree not found: $target_dir"
            exit 1
        fi
        session_name="${repo}${SEP}${worktree}${SEP}kw-${name}"
        session_path="$repo/$worktree/kw-${name}"
    else
        target_dir="$repo_dir"
        session_name="${repo}${SEP}kw-${name}"
        session_path="$repo/kw-${name}"
    fi

    local queue_file
    local status_file
    local session_dir
    queue_file=$(kw_queue_file "$repo" "$name")
    status_file=$(kw_status_file "$repo" "$name")
    session_dir=$(kw_session_dir "$repo" "$name")

    mkdir -p "$(dirname "$queue_file")" "$(dirname "$status_file")" "$session_dir"

    kw_write_meta "$repo" "$name" "$tags" "$description" "$session_dir" "$queue_file" "$status_file" "$session_path"

    if [ -z "$tags" ]; then
        tags=$(jq -r '.tags // [] | join(",")' "$(kw_meta_file "$repo" "$name")" 2>/dev/null)
    fi

    local backend
    backend=$(session_backend "$session_name")
    if [ "$backend" = "tmux" ]; then
        if [ "$attach" -eq 1 ]; then
            tmux attach -t "$session_name"
        else
            echo "Knowledge worker already running: $(to_display_name "$session_name")"
        fi
        return
    fi

    tmux new-session -d -s "$session_name" -c "$target_dir"

    local cmd_line
    local meta_file
    meta_file=$(kw_meta_file "$repo" "$name")
    printf -v cmd_line 'PI_ROLE=knowledge-worker PI_KW_ROLE=1 PI_KW_REPO=%q PI_KW_NAME=%q PI_KW_TAGS=%q PI_QUEUE_FILE=%q PI_STATUS_FILE=%q PI_KW_META_FILE=%q pi --session-dir %q' \
        "$repo" "$name" "$tags" "$queue_file" "$status_file" "$meta_file" "$session_dir"
    tmux send-keys -t "$session_name" "$cmd_line" C-m

    if [ -n "$bootstrap_file" ]; then
        if [ ! -f "$bootstrap_file" ]; then
            echo "Bootstrap file not found: $bootstrap_file"
        else
            bootstrap=$(cat "$bootstrap_file")
        fi
    fi

    if [ -z "$bootstrap" ]; then
        bootstrap=$'You are a knowledge-worker agent.\nFirst, familiarize yourself: read AGENTS.md and README.md, then skim docs/plans relevant to your domain and locate key packages/apps.\nSummarize your understanding and create a short guide for the PM (constraints, pitfalls, QA checks).\nRun /kw-tags tag1,tag2 and /kw-note inside your session (not in a response).'
    fi

    if [ -n "$bootstrap" ]; then
        send_pi "$session_path" "$bootstrap"
    fi

    echo -e "${GREEN}Knowledge worker started!${RESET}"
    echo -e "  session: ${CYAN}dev ${session_path}${RESET}"
    echo -e "  queue: ${DIM}${queue_file}${RESET}"
}

kill_session() {
    local input="$1"
    # Convert path-style to session name
    local session=$(to_session_name "$input")
    echo "Killing session: $session"

    local backend
    backend=$(session_backend "$session")

    if [ "$backend" = "tmux" ]; then
        tmux kill-session -t "$session"
        return
    fi

    echo "Session not found: $input"
    exit 1
}

cleanup_worktree() {
    local input="$1"
    shift

    local dry_run=0
    local force=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run|-n)
                dry_run=1
                shift
                ;;
            --force|-f)
                force=1
                shift
                ;;
            *)
                break
                ;;
        esac
    done

    if [ -z "$input" ]; then
        echo "Usage: dev cleanup <repo>/<worktree> [--dry-run] [--force]"
        echo ""
        echo "Kill the worktree session, remove the worktree, and delete the branch."
        echo "Refuses to delete branches with commits not in main unless --force is set."
        exit 1
    fi

    IFS='/' read -ra parts <<< "$input"
    local repo="${parts[0]}"
    local worktree="${parts[1]:-}"
    if [ -z "$worktree" ]; then
        echo "Usage: dev cleanup <repo>/<worktree> [--dry-run] [--force]"
        exit 1
    fi

    local repo_dir="$PROJECTS_DIR/$repo"
    if [ ! -d "$repo_dir/.bare" ]; then
        echo "Not a worktree-based repo: $repo"
        exit 1
    fi

    local wt_dir="$repo_dir/$worktree"
    if [ ! -d "$wt_dir" ]; then
        echo "Worktree not found: $wt_dir"
        exit 1
    fi

    local session_name="${repo}${SEP}${worktree}"

    local ahead_count=0
    ahead_count=$(cd "$repo_dir" && git --git-dir=.bare rev-list --left-right --count "main...$worktree" 2>/dev/null | awk '{print $2}')
    ahead_count=${ahead_count:-0}

    if [ "$dry_run" -eq 1 ]; then
        echo "Would kill sessions matching: $session_name*"
        echo "Would remove worktree: $wt_dir"
        echo "Would delete branch: $worktree"
        if [ "$ahead_count" -gt 0 ]; then
            echo "Would delete $worktree with $ahead_count commits not in main (--force required)."
        fi
        return
    fi

    if [ "$ahead_count" -gt 0 ] && [ "$force" -ne 1 ]; then
        echo "Refusing to delete $worktree: $ahead_count commits not in main."
        echo "Use --force to delete anyway."
        exit 1
    fi

    # Kill base session and all sub-sessions (e.g., repo_wt_pi, repo_wt_claude)
    local sess
    for sess in $(get_all_sessions | grep -E "^${session_name}($|${SEP})"); do
        tmux kill-session -t "$sess" 2>/dev/null || true
    done

    (cd "$repo_dir" && git --git-dir=.bare worktree remove "$worktree")
    (cd "$repo_dir" && git --git-dir=.bare branch -D "$worktree")

    echo "Cleaned: $input"
}

kill_all_sessions() {
    echo "Killing all sessions..."
    tmux kill-server 2>/dev/null || true
}

send_keys() {
    local input="$1"
    shift

    if [ -z "$input" ] || [ $# -eq 0 ]; then
        echo "Usage: dev send <session> <keys...>"
        echo ""
        echo "Send raw keys to a tmux session (like tmux send-keys)."
        echo "Note: Enter/Return are sent as C-m."
        echo ""
        echo "Example:"
        echo "  dev send replay/arb-admin-sse 'pi' Enter"
        exit 1
    fi

    local session
    session=$(to_session_name "$input")

    local backend
    backend=$(session_backend "$session")

    if [ -z "$backend" ]; then
        echo "Session not found: $input"
        exit 1
    fi

    if [ "$backend" != "tmux" ]; then
        echo "Session backend not supported for send: $backend"
        exit 1
    fi

    local keys=()
    local key
    for key in "$@"; do
        case "$key" in
            Enter|enter|Return|RETURN)
                keys+=("C-m")
                ;;
            *)
                keys+=("$key")
                ;;
        esac
    done

    tmux send-keys -t "$session" "${keys[@]}"
}

send_pi() {
    local input="$1"
    shift
    local mode="followUp"
    local message=""
    local await_completion=1
    local timeout_seconds=0

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --steer|-s|--enter|-e)
                mode="steer"
                shift
                ;;
            --follow-up|-f|--queue|-q)
                mode="followUp"
                shift
                ;;
            --await|-w|--wait)
                await_completion=1
                shift
                ;;
            --no-await|--no-wait)
                await_completion=0
                shift
                ;;
            --timeout|-t)
                if [ -z "${2:-}" ]; then
                    echo "Missing value for --timeout"
                    exit 1
                fi
                timeout_seconds="$2"
                shift 2
                ;;
            *)
                if [ -z "$message" ]; then
                    message="$1"
                else
                    message="$message $1"
                fi
                shift
                ;;
        esac
    done

    if [ -z "$input" ] || [ -z "$message" ]; then
        echo "Usage: dev send-pi <session> [--enter|--steer] <message>"
        echo ""
        echo "Send a message to a pi agent's queue."
        echo ""
        echo "Options:"
        echo "  --follow-up, -f  Queue for after agent finishes (default, like Alt+Enter)"
        echo "  --queue, -q      Alias for --follow-up"
        echo "  --steer, -s      Interrupt agent mid-run (like Enter)"
        echo "  --enter, -e      Alias for --steer"
        echo "  --await, -w      Wait for the next completion after sending (default)"
        echo "  --wait           Alias for --await"
        echo "  --no-await       Send without waiting"
        echo "  --timeout, -t <s> Exit after N seconds if no completion"
        echo ""
        echo "Examples:"
        echo "  dev send-pi replay/feature 'focus on the error handling next'"
        echo "  dev send-pi replay/main --enter 'stop and explain what you are doing'"
        echo "  dev send-pi replay/prod-fix --await 'review the plan and respond'"
        echo ""
        echo "Reminder: Always read the agent's last message before nudging."
        echo "  dev pi-status <session> --messages 1"
        echo "  dev queue-status <session> -m"
        echo "  dev requirements <session>"
        echo "Note: Requires the message-queue extension in ~/.pi/agent/extensions/"
        exit 1
    fi

    # Convert session path to directory path, then to queue file
    IFS='/' read -ra parts <<< "$input"
    local repo="${parts[0]}"
    local worktree="${parts[1]:-main}"
    local repo_dir="$PROJECTS_DIR/$repo"
    local target_dir=""
    local sub=""

    if [ -d "$repo_dir/.bare" ]; then
        target_dir="$repo_dir/$worktree"
        sub="${parts[2]:-}"
    else
        target_dir="$repo_dir"
        sub="${parts[1]:-}"
    fi

    if [ ! -d "$target_dir" ]; then
        echo "Directory not found: $target_dir"
        exit 1
    fi

    if [[ "$sub" == kw-* ]]; then
        local kw_name
        local queue_file
        kw_name="${sub#kw-}"
        queue_file=$(kw_meta_get "$repo" "$kw_name" "queueFile")
        if [ -z "$queue_file" ]; then
            queue_file=$(kw_queue_file "$repo" "$kw_name")
        fi
        mkdir -p "$(dirname "$queue_file")"

        local json_line
        json_line=$(jq -nc --arg message "$message" --arg mode "$mode" '{message: $message, mode: $mode}')
        if ! echo "$json_line" | jq -e . >/dev/null 2>&1; then
            echo "ERROR: message contains characters that break JSON encoding" >&2
            exit 1
        fi
        echo "$json_line" >> "$queue_file"

        local display_name
        display_name=$(to_display_name "$(to_session_name "$input")")
        echo -e "Queued for ${GREEN}${display_name}${RESET} (${mode}): $message"
        return
    fi

    if [ -n "$sub" ]; then
        local sub_dir="$target_dir/$sub"
        local dot_sub_dir="$target_dir/.${sub}"
        local chosen=""

        for candidate in "$sub_dir" "$dot_sub_dir"; do
            if [ -d "$candidate" ]; then
                local safe_candidate
                safe_candidate=$(echo "$candidate" | tr '[:upper:]' '[:lower:]' | sed 's|/|-|g' | sed 's|^-||')
                local session_candidate="$HOME/.pi/agent/sessions/--${safe_candidate}--"
                if [ -d "$session_candidate" ]; then
                    chosen="$candidate"
                    break
                fi
            fi
        done

        if [ -n "$chosen" ]; then
            target_dir="$chosen"
        fi
    fi

    # Convert path to queue file format (same as extension - lowercase)
    local safe_path
    safe_path=$(echo "$target_dir" | tr '[:upper:]' '[:lower:]' | sed 's|/|-|g' | sed 's|^-||')
    local queue_file="$HOME/.pi/queues/${safe_path}.jsonl"

    # Ensure queue directory exists
    mkdir -p "$HOME/.pi/queues"

    # Append message as JSONL (safe JSON encoding)
    local json_line
    json_line=$(jq -nc --arg message "$message" --arg mode "$mode" '{message: $message, mode: $mode}')
    if ! echo "$json_line" | jq -e . >/dev/null 2>&1; then
        echo "ERROR: message contains characters that break JSON encoding" >&2
        exit 1
    fi
    echo "$json_line" >> "$queue_file"

    local display_name
    display_name=$(to_display_name "$(to_session_name "$input")")
    echo -e "Queued for ${GREEN}${display_name}${RESET} (${mode}): $message"

    if [ "$await_completion" -eq 1 ]; then
        if [ "$timeout_seconds" -gt 0 ]; then
            pi_subscribe "$input" --next --timeout "$timeout_seconds"
        else
            pi_subscribe "$input" --next
        fi
    fi
}

default_pi_session_from_cwd() {
    local cwd="${PWD}"

    if [[ "$cwd" != "$PROJECTS_DIR"/* ]]; then
        return 1
    fi

    local rel="${cwd#$PROJECTS_DIR/}"
    local repo="${rel%%/*}"

    if [ -z "$repo" ]; then
        return 1
    fi

    local repo_dir="$PROJECTS_DIR/$repo"
    if [ ! -d "$repo_dir" ]; then
        return 1
    fi

    if [ -d "$repo_dir/.bare" ]; then
        local rest="${rel#*/}"
        local worktree="${rest%%/*}"
        if [ -z "$rest" ] || [ "$rest" = "$rel" ] || [ -z "$worktree" ]; then
            worktree="main"
        fi
        echo "$repo/$worktree/pi"
    else
        echo "$repo/pi"
    fi
}

pi_gh_assign() {
    local issue=""
    local timeout_seconds=900
    local await_completion=1

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --timeout|-t)
                if [ -z "${2:-}" ]; then
                    echo "Missing value for --timeout"
                    exit 1
                fi
                timeout_seconds="$2"
                shift 2
                ;;
            --no-await|--no-wait)
                await_completion=0
                shift
                ;;
            --await|--wait)
                await_completion=1
                shift
                ;;
            *)
                if [ -z "$issue" ]; then
                    issue="$1"
                else
                    echo "Unexpected argument: $1"
                    exit 1
                fi
                shift
                ;;
        esac
    done

    if [ -z "$issue" ]; then
        echo "Usage: dev pi-gh-assign <issue-number> [--timeout <s>]"
        echo ""
        echo "Send a GitHub issue assignment prompt to the current repo's pi session."
        echo ""
        echo "Options:"
        echo "  --timeout, -t <s> Exit after N seconds if no completion"
        echo "  --no-await       Send without waiting"
        exit 1
    fi

    if ! [[ "$issue" =~ ^[0-9]+$ ]]; then
        echo "Issue number must be numeric: $issue"
        exit 1
    fi

    local session
    session=$(default_pi_session_from_cwd || true)

    if [ -z "$session" ]; then
        echo "Unable to infer session from cwd ($PWD)."
        echo "Run from inside <projects-root>/<repo>/<worktree>/, or use dev send-pi directly."
        exit 1
    fi

    local message
    printf -v message "%s\n" \
        "You are assigned to GitHub issue #${issue}." \
        "" \
        "Follow this process:" \
        "1) Read the issue with GitHub CLI and include comments:" \
        "   gh issue view ${issue} --comments" \
        "2) Implement ALL required changes in this worktree (code + tests + docs as needed). If this is a major change, update README(s) and AGENTS.md with relevant context." \
        "3) Commit with \"fixes #${issue}\" in the commit message (exact string)." \
        "4) Validate everything described in the issue. Do not leave TODOs or partial work." \
        "5) Do not output a plan and wait for approval — proceed directly with implementation." \
        "6) Report back with a summary and any follow-ups."

    local args=()
    if [ "$await_completion" -eq 0 ]; then
        args+=(--no-await)
    fi
    if [ "$timeout_seconds" -gt 0 ]; then
        args+=(--timeout "$timeout_seconds")
    fi

    send_pi "$session" "${args[@]}" "$message"
}

review_session() {
    local input="$1"

    if [ -z "$input" ]; then
        echo "Usage: dev review <session>"
        echo ""
        echo "Show the latest completion status plus git log/diff if commits exist."
        exit 1
    fi

    IFS='/' read -ra parts <<< "$input"
    local repo="${parts[0]}"
    local worktree="${parts[1]:-main}"
    local repo_dir="$PROJECTS_DIR/$repo"
    local target_dir=""
    local sub=""

    if [ -d "$repo_dir/.bare" ]; then
        target_dir="$repo_dir/$worktree"
        sub="${parts[2]:-}"
    else
        target_dir="$repo_dir"
        sub="${parts[1]:-}"
    fi

    if [ ! -d "$target_dir" ]; then
        echo "Directory not found: $target_dir"
        exit 1
    fi

    local status_file=""
    local queue_file=""
    local session_dir="$target_dir"

    if [[ "$sub" == kw-* ]]; then
        local kw_name
        kw_name="${sub#kw-}"
        status_file=$(kw_meta_get "$repo" "$kw_name" "statusFile")
        if [ -z "$status_file" ]; then
            status_file=$(kw_status_file "$repo" "$kw_name")
        fi
        queue_file=$(kw_meta_get "$repo" "$kw_name" "queueFile")
        if [ -z "$queue_file" ]; then
            queue_file=$(kw_queue_file "$repo" "$kw_name")
        fi
    else
        if [ -n "$sub" ]; then
            local sub_dir="$target_dir/$sub"
            local dot_sub_dir="$target_dir/.${sub}"
            local chosen=""

            for candidate in "$sub_dir" "$dot_sub_dir"; do
                if [ -d "$candidate" ]; then
                    local safe_candidate
                    safe_candidate=$(echo "$candidate" | tr '[:upper:]' '[:lower:]' | sed 's|/|-|g' | sed 's|^-||')
                    local session_candidate="$HOME/.pi/agent/sessions/--${safe_candidate}--"
                    if [ -d "$session_candidate" ]; then
                        chosen="$candidate"
                        break
                    fi
                fi
            done

            if [ -n "$chosen" ]; then
                session_dir="$chosen"
            fi
        fi

        local safe_path
        safe_path=$(echo "$session_dir" | tr '[:upper:]' '[:lower:]' | sed 's|/|-|g' | sed 's|^-||')
        status_file="$HOME/.pi/status/${safe_path}.jsonl"
        queue_file="$HOME/.pi/queues/${safe_path}.jsonl"

        if [ ! -f "$status_file" ]; then
            safe_path=$(echo "$session_dir" | sed 's|/|-|g' | sed 's|^-||')
            status_file="$HOME/.pi/status/${safe_path}.jsonl"
            queue_file="$HOME/.pi/queues/${safe_path}.jsonl"
        fi
    fi

    if [ ! -f "$status_file" ]; then
        echo "No status file found for: $input"
        echo "Expected: $status_file"
        exit 1
    fi

    format_time() {
        local ts_ms="$1"
        if [ -z "$ts_ms" ] || [ "$ts_ms" = "null" ]; then
            echo "unknown"
            return
        fi
        if ! [[ "$ts_ms" =~ ^[0-9]+$ ]]; then
            echo "unknown"
            return
        fi
        local ts_s=$((ts_ms / 1000))
        date -r "$ts_s" "+%Y-%m-%d %H:%M:%S"
    }

    local last_line
    last_line=$(tail -n 1 "$status_file" 2>/dev/null || true)

    if [ -z "$last_line" ]; then
        echo "(no status entries)"
    else
        local status
        local ts_ms
        local msg
        local stop_reason
        local error_msg
        status=$(echo "$last_line" | jq -r '.status // "done"' 2>/dev/null)
        ts_ms=$(echo "$last_line" | jq -r '.timestamp // 0' 2>/dev/null)
        msg=$(echo "$last_line" | jq -r '.message // ""' 2>/dev/null)
        stop_reason=$(echo "$last_line" | jq -r '.stopReason // empty' 2>/dev/null)
        error_msg=$(echo "$last_line" | jq -r '.errorMessage // empty' 2>/dev/null)

        if [ -z "$msg" ]; then
            msg="(no text)"
        fi

        local status_label="$status"
        if [ -n "$stop_reason" ]; then
            status_label="$status ($stop_reason)"
        fi
        if [ -n "$error_msg" ]; then
            status_label="$status error: $error_msg"
        fi

        echo -e "${BOLD}Status:${RESET} $status_label"
        echo -e "${DIM}Time:${RESET} $(format_time "$ts_ms")"
        echo -e "${BOLD}Summary:${RESET} $msg"

        if [ "$status" = "working" ]; then
            echo -e "${YELLOW}Warning:${RESET} agent appears to be mid-work."
        else
            if [ -f "$queue_file" ] && [ -s "$queue_file" ]; then
                echo -e "${YELLOW}Warning:${RESET} queued messages are pending delivery."
            else
                echo -e "${DIM}Agent idle; waiting for instructions.${RESET}"
            fi
        fi
    fi

    echo ""

    if [ ! -d "$target_dir/.git" ] && [ ! -d "$target_dir/.bare" ]; then
        if ! git -C "$target_dir" rev-parse --git-dir >/dev/null 2>&1; then
            echo "No git repository found at: $target_dir"
            return
        fi
    fi

    local base_branch=""
    if git -C "$target_dir" show-ref --verify --quiet refs/heads/main; then
        base_branch="main"
    elif git -C "$target_dir" show-ref --verify --quiet refs/heads/master; then
        base_branch="master"
    fi

    if [ -n "$base_branch" ]; then
        local commit_count
        commit_count=$(git -C "$target_dir" rev-list --count "${base_branch}..HEAD" 2>/dev/null || echo 0)

        if [ "$commit_count" -eq 0 ]; then
            echo "No commits ahead of ${base_branch}."
        else
            echo -e "${BOLD}Commits (${base_branch}..HEAD):${RESET}"
            git -C "$target_dir" log --oneline --decorate "${base_branch}..HEAD"
            echo ""
            echo -e "${BOLD}Diff (${base_branch}..HEAD):${RESET}"
            git -C "$target_dir" diff "${base_branch}..HEAD"
        fi
    else
        echo -e "${BOLD}Commits (last 5):${RESET}"
        git -C "$target_dir" log --oneline -n 5
        echo ""
        echo -e "${BOLD}Working tree status:${RESET}"
        git -C "$target_dir" status -sb
    fi
}

review_loop() {
    echo "Review loop (PM session):"
    echo "  1) List sessions: dev list"
    echo "  2) For each worktree agent:"
    echo "     - Read last message: dev pi-status <session> --messages 1"
    echo "     - Check requirements: dev requirements <session>"
    echo "     - If feedback requested, reply before reviewing"
    echo "  3) When agent says done: run code review skill"
    echo "  4) If review is clean: merge locally into main"
    echo "  5) Run: bash sleep 300 (in this session, foreground)"
    echo "  6) After sleep finishes, go back to step 1 and repeat"
    echo "  7) Do NOT write scripts, nohup, or background loops"
}

reboot_sessions() {
    local dry_run=0
    if [ "${1:-}" = "--dry-run" ]; then
        dry_run=1
        shift
    fi

    if ! command -v tmux >/dev/null 2>&1; then
        echo "tmux is required for dev reboot"
        exit 1
    fi

    echo -e "${BOLD}Rebooting sessions${RESET}"
    echo ""

    # Hub sessions
    if ! tmux has-session -t "hub${SEP}pi" 2>/dev/null; then
        if [ "$dry_run" -eq 1 ]; then
            echo "Would create: hub/pi"
        else
            tmux new-session -d -s "hub${SEP}pi" -c "$PROJECTS_DIR"
            tmux send-keys -t "hub${SEP}pi" "pi" C-m
            echo "Created: hub/pi"
        fi
    fi
    if ! tmux has-session -t "hub${SEP}claude" 2>/dev/null; then
        if [ "$dry_run" -eq 1 ]; then
            echo "Would create: hub/claude"
        else
            tmux new-session -d -s "hub${SEP}claude" -c "$PROJECTS_DIR"
            tmux send-keys -t "hub${SEP}claude" "claude --dangerously-skip-permissions" C-m
            echo "Created: hub/claude"
        fi
    fi

    for dir in "$PROJECTS_DIR"/*/; do
        [ -d "$dir" ] || continue
        local project
        project=$(basename "$dir")
        [[ "$project" == "dev" ]] && continue

        if [ -d "$dir/.bare" ]; then
            # Main worktree gets claude + pi sessions
            if [ -d "$dir/main" ]; then
                local main_claude
                local main_pi
                main_claude="${project}${SEP}main${SEP}claude"
                main_pi="${project}${SEP}main${SEP}pi"
                if ! tmux has-session -t "$main_claude" 2>/dev/null; then
                    if [ "$dry_run" -eq 1 ]; then
                        echo "Would create: $project/main/claude"
                    else
                        tmux new-session -d -s "$main_claude" -c "$dir/main"
                        tmux send-keys -t "$main_claude" "claude --dangerously-skip-permissions" C-m
                        echo "Created: $project/main/claude"
                    fi
                fi
                if ! tmux has-session -t "$main_pi" 2>/dev/null; then
                    if [ "$dry_run" -eq 1 ]; then
                        echo "Would create: $project/main/pi"
                    else
                        tmux new-session -d -s "$main_pi" -c "$dir/main"
                        tmux send-keys -t "$main_pi" "pi" C-m
                        echo "Created: $project/main/pi"
                    fi
                fi
            fi

            # Other worktrees: pi sessions
            for wt_dir in "$dir"/*/; do
                [ -d "$wt_dir" ] || continue
                local worktree
                worktree=$(basename "$wt_dir")
                [[ "$worktree" == ".bare" ]] && continue
                [[ "$worktree" == "main" ]] && continue

                local pi_session
                pi_session="${project}${SEP}${worktree}${SEP}pi"
                if tmux has-session -t "$pi_session" 2>/dev/null; then
                    continue
                fi

                if [ "$dry_run" -eq 1 ]; then
                    echo "Would create: $project/$worktree/pi"
                else
                    tmux new-session -d -s "$pi_session" -c "$wt_dir"
                    tmux send-keys -t "$pi_session" "pi" C-m
                    echo "Created: $project/$worktree/pi"
                fi
            done
        else
            # Regular repo: claude + pi sessions
            local repo_claude
            local repo_pi
            repo_claude="${project}${SEP}claude"
            repo_pi="${project}${SEP}pi"
            if ! tmux has-session -t "$repo_claude" 2>/dev/null; then
                if [ "$dry_run" -eq 1 ]; then
                    echo "Would create: $project/claude"
                else
                    tmux new-session -d -s "$repo_claude" -c "$dir"
                    tmux send-keys -t "$repo_claude" "claude --dangerously-skip-permissions" C-m
                    echo "Created: $project/claude"
                fi
            fi
            if ! tmux has-session -t "$repo_pi" 2>/dev/null; then
                if [ "$dry_run" -eq 1 ]; then
                    echo "Would create: $project/pi"
                else
                    tmux new-session -d -s "$repo_pi" -c "$dir"
                    tmux send-keys -t "$repo_pi" "pi" C-m
                    echo "Created: $project/pi"
                fi
            fi
        fi
    done
}

requirements() {
    local input="$1"
    shift

    local action="show"
    local append=0
    local clear=0
    local message=""

    if [ -z "$input" ]; then
        echo "Usage: dev requirements <session> [--append|--clear] [text]"
        echo ""
        echo "Store or view optional requirements/notes for an agent session."
        echo ""
        echo "Examples:"
        echo "  dev requirements replay/feature/pi \"Needs feedback on API shape\""
        echo "  dev requirements replay/feature/pi --append \"Confirm edge cases\""
        echo "  dev requirements replay/feature/pi"
        exit 1
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --append|-a)
                append=1
                shift
                ;;
            --clear|-c)
                clear=1
                shift
                ;;
            --show|-s)
                action="show"
                shift
                ;;
            *)
                if [ -z "$message" ]; then
                    message="$1"
                else
                    message="$message $1"
                fi
                shift
                ;;
        esac
    done

    local session
    session=$(to_session_name "$input")
    local req_dir="$HOME/.pi/requirements"
    local req_file="$req_dir/${session}.txt"

    mkdir -p "$req_dir"

    if [ "$clear" -eq 1 ]; then
        rm -f "$req_file"
        echo "Cleared requirements: $input"
        return
    fi

    if [ -n "$message" ]; then
        if [ "$append" -eq 1 ] && [ -f "$req_file" ]; then
            printf "%s\n" "$message" >> "$req_file"
        else
            printf "%s\n" "$message" > "$req_file"
        fi
    fi

    if [ ! -f "$req_file" ] || [ ! -s "$req_file" ]; then
        echo "(no requirements)"
        return
    fi

    echo "Requirements for $input:"
    cat "$req_file"
}

pi_status() {
    local input="$1"
    shift

    local messages_count=""
    local show_tools=0
    local show_errors=0
    local show_cost=0
    local follow=0
    local since=""
    local show_summary=1
    local view_flags=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --messages|-m)
                if [ -z "${2:-}" ]; then
                    echo "Missing value for --messages"
                    exit 1
                fi
                messages_count="$2"
                shift 2
                view_flags=1
                ;;
            --tools|-t)
                show_tools=1
                shift
                view_flags=1
                ;;
            --errors|-e)
                show_errors=1
                shift
                view_flags=1
                ;;
            --cost|-c)
                show_cost=1
                shift
                view_flags=1
                ;;
            --since)
                if [ -z "${2:-}" ]; then
                    echo "Missing value for --since"
                    exit 1
                fi
                since="$2"
                shift 2
                ;;
            --follow|-f)
                follow=1
                shift
                ;;
            *)
                echo "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    if [ -z "$input" ]; then
        echo "Usage: dev pi-status <session> [options]"
        echo ""
        echo "Show recent activity from a pi agent's session."
        echo ""
        echo "Options:"
        echo "  --messages, -m <n>  Show last n user/assistant messages"
        echo "  --tools, -t         Show recent tool calls"
        echo "  --errors, -e        Show errors/failures only"
        echo "  --cost, -c          Show token usage and cost totals"
        echo "  --since <window>    Limit to recent activity (e.g., 10m, 2h, 1d)"
        echo "  --follow, -f        Tail new activity (like tail -f)"
        exit 1
    fi

    if [ "$view_flags" -eq 1 ]; then
        show_summary=0
    fi

    local cutoff_ms=0
    if [ -n "$since" ]; then
        if [[ "$since" =~ ^([0-9]+)([smhd]?)$ ]]; then
            local amount="${BASH_REMATCH[1]}"
            local unit="${BASH_REMATCH[2]}"
            local seconds=0
            case "$unit" in
                ""|"s") seconds="$amount" ;;
                "m") seconds=$((amount * 60)) ;;
                "h") seconds=$((amount * 3600)) ;;
                "d") seconds=$((amount * 86400)) ;;
                *)
                    echo "Invalid --since value: $since (use Ns, Nm, Nh, Nd)"
                    exit 1
                    ;;
            esac
            local now_s
            now_s=$(date +%s)
            cutoff_ms=$(((now_s - seconds) * 1000))
        else
            echo "Invalid --since value: $since (use Ns, Nm, Nh, Nd)"
            exit 1
        fi
    fi

    IFS='/' read -ra parts <<< "$input"
    local repo="${parts[0]}"
    local worktree="${parts[1]:-main}"
    local repo_dir="$PROJECTS_DIR/$repo"
    local target_dir=""
    local sub=""

    if [ -d "$repo_dir/.bare" ]; then
        target_dir="$repo_dir/$worktree"
        sub="${parts[2]:-}"
    else
        target_dir="$repo_dir"
        sub="${parts[1]:-}"
    fi

    if [ ! -d "$target_dir" ]; then
        echo "Directory not found: $target_dir"
        exit 1
    fi

    local session_dir=""
    if [[ "$sub" == kw-* ]]; then
        local kw_name
        kw_name="${sub#kw-}"
        session_dir=$(kw_meta_get "$repo" "$kw_name" "sessionDir")
        if [ -z "$session_dir" ]; then
            session_dir=$(kw_session_dir "$repo" "$kw_name")
        fi
    else
        local safe_path
        safe_path=$(echo "$target_dir" | tr '[:upper:]' '[:lower:]' | sed 's|/|-|g' | sed 's|^-||')
        session_dir="$HOME/.pi/agent/sessions/--${safe_path}--"

        if [ ! -d "$session_dir" ]; then
            safe_path=$(echo "$target_dir" | sed 's|/|-|g' | sed 's|^-||')
            session_dir="$HOME/.pi/agent/sessions/--${safe_path}--"
        fi
    fi

    if [ ! -d "$session_dir" ]; then
        echo "No pi sessions found for: $input"
        echo ""
        echo "Available sessions:"
        ls -1 "$HOME/.pi/agent/sessions/" 2>/dev/null | head -10
        exit 1
    fi

    local session_file
    session_file=$(ls "$session_dir"/*.jsonl 2>/dev/null | sort | tail -1)
    if [ -z "$session_file" ]; then
        echo "No session files found"
        exit 1
    fi

    format_time() {
        local ts_ms="$1"
        if [ -z "$ts_ms" ] || [ "$ts_ms" = "null" ]; then
            echo "unknown"
            return
        fi
        if ! [[ "$ts_ms" =~ ^[0-9]+$ ]]; then
            echo "unknown"
            return
        fi
        local ts_s=$((ts_ms / 1000))
        date -r "$ts_s" "+%Y-%m-%d %H:%M:%S"
    }

    echo -e "${BOLD}Session:${RESET} $input"
    echo -e "${DIM}File: $session_file${RESET}"
    if [ -n "$since" ]; then
        echo -e "${DIM}Window: last $since${RESET}"
    fi
    echo ""

    if [ "$show_summary" -eq 1 ]; then
        echo -e "${BOLD}Summary:${RESET}"
        local last_message_json
        last_message_json=$(jq -c --argjson cutoff "$cutoff_ms" 'select(.type=="message") | select((.message.timestamp // 0) >= $cutoff)' "$session_file" | tail -1)

        if [ -z "$last_message_json" ]; then
            echo "  No activity"
        else
            local last_role
            local last_ts_ms
            local last_text
            local last_status
            last_role=$(echo "$last_message_json" | jq -r '.message.role // "unknown"')
            last_ts_ms=$(echo "$last_message_json" | jq -r '.message.timestamp // empty')
            last_text=$(echo "$last_message_json" | jq -r '
                def text_of:
                  if (.message.content | type) == "string" then .message.content
                  else ([.message.content[]? | select(.type=="text") | .text] | join(" ")) end;
                text_of // ""')
            if [ -z "$last_text" ]; then
                last_text="(no text)"
            fi

            case "$last_role" in
                assistant)
                    local stop_reason
                    local error_msg
                    stop_reason=$(echo "$last_message_json" | jq -r '.message.stopReason // empty')
                    error_msg=$(echo "$last_message_json" | jq -r '.message.errorMessage // empty')
                    last_status="assistant"
                    if [ -n "$stop_reason" ]; then
                        last_status="assistant ($stop_reason)"
                    fi
                    if [ -n "$error_msg" ]; then
                        last_status="assistant error: $error_msg"
                    fi
                    ;;
                toolResult)
                    local tool_name
                    local is_error
                    tool_name=$(echo "$last_message_json" | jq -r '.message.toolName // "tool"')
                    is_error=$(echo "$last_message_json" | jq -r '.message.isError // false')
                    if [ "$is_error" = "true" ]; then
                        last_status="tool error: $tool_name"
                    else
                        last_status="tool result: $tool_name"
                    fi
                    ;;
                bashExecution)
                    local exit_code
                    local cancelled
                    exit_code=$(echo "$last_message_json" | jq -r '.message.exitCode // empty')
                    cancelled=$(echo "$last_message_json" | jq -r '.message.cancelled // false')
                    if [ "$cancelled" = "true" ]; then
                        last_status="bash cancelled"
                    elif [ -n "$exit_code" ]; then
                        last_status="bash exit $exit_code"
                    else
                        last_status="bash execution"
                    fi
                    ;;
                user)
                    last_status="user"
                    ;;
                *)
                    last_status="$last_role"
                    ;;
            esac

            echo "  Last message: [$(format_time "$last_ts_ms")] $last_role"
            echo "  Status: $last_status"
            echo "  Text: $last_text"

            local last_assistant_json
            last_assistant_json=$(jq -c --argjson cutoff "$cutoff_ms" 'select(.type=="message" and .message.role=="assistant") | select((.message.timestamp // 0) >= $cutoff)' "$session_file" | tail -1)
            if [ -n "$last_assistant_json" ]; then
                local total_tokens
                local input_tokens
                local output_tokens
                local cost_total
                total_tokens=$(echo "$last_assistant_json" | jq -r '.message.usage.totalTokens // 0')
                input_tokens=$(echo "$last_assistant_json" | jq -r '.message.usage.input // 0')
                output_tokens=$(echo "$last_assistant_json" | jq -r '.message.usage.output // 0')
                cost_total=$(echo "$last_assistant_json" | jq -r '.message.usage.cost.total // 0')
                printf "  Tokens: %s (in %s / out %s)\n" "$total_tokens" "$input_tokens" "$output_tokens"
                printf "  Cost: $%.4f\n" "$cost_total"
            fi
        fi
        echo ""
    fi

    if [ -n "$messages_count" ]; then
        echo -e "${BOLD}Messages (last $messages_count):${RESET}"
        local message_lines
        message_lines=$(jq -r --argjson cutoff "$cutoff_ms" '
            def text_of:
              if (.message.content | type) == "string" then .message.content
              else ([.message.content[]? | select(.type=="text") | .text] | join(" ")) end;
            def clean_text:
              gsub("[\\t\\r\\n]+"; " ");
            select(.type=="message")
            | select((.message.timestamp // 0) >= $cutoff)
            | select(.message.role=="user" or .message.role=="assistant")
            | (.message.timestamp|tostring) + "\t" + .message.role + "\t" + ((text_of // "") | clean_text)' "$session_file" | tail -n "$messages_count")

        if [ -z "$message_lines" ]; then
            echo "  (none)"
        else
            echo "$message_lines" | while IFS=$'\t' read -r ts role text; do
                if [ -z "$text" ]; then
                    text="(no text)"
                fi
                echo "  [$(format_time "$ts")] $role: $text"
            done
        fi
        echo ""
    fi

    if [ "$show_tools" -eq 1 ]; then
        echo -e "${BOLD}Tool calls:${RESET}"
        local tool_lines
        tool_lines=$(jq -r --argjson cutoff "$cutoff_ms" '
            select(.type=="message" and .message.role=="assistant")
            | select((.message.timestamp // 0) >= $cutoff)
            | . as $m
            | $m.message.content[]?
            | select(.type=="toolCall")
            | ($m.message.timestamp|tostring) + "\t" + .name' "$session_file" | tail -n 20)

        if [ -z "$tool_lines" ]; then
            echo "  (none)"
        else
            echo "$tool_lines" | while IFS=$'\t' read -r ts name; do
                echo "  [$(format_time "$ts")] $name"
            done
        fi
        echo ""
    fi

    if [ "$show_errors" -eq 1 ]; then
        echo -e "${BOLD}Errors:${RESET}"
        local error_lines
        error_lines=$(jq -r --argjson cutoff "$cutoff_ms" '
            select(.type=="message")
            | select((.message.timestamp // 0) >= $cutoff)
            | if .message.role=="toolResult" and (.message.isError==true) then
                (.message.timestamp|tostring) + "\ttoolResult\t" + (.message.toolName // "tool")
              elif .message.role=="assistant" and ((.message.stopReason=="error") or (.message.errorMessage // "") != "") then
                (.message.timestamp|tostring) + "\tassistant\t" + (.message.errorMessage // .message.stopReason // "error")
              elif .message.role=="bashExecution" and ((.message.cancelled==true) or ((.message.exitCode // 0) != 0)) then
                (.message.timestamp|tostring) + "\tbash\t" + (if .message.cancelled==true then "cancelled" else "exit " + ((.message.exitCode // 0)|tostring) end)
              else empty end' "$session_file" | tail -n 20)

        if [ -z "$error_lines" ]; then
            echo "  (none)"
        else
            echo "$error_lines" | while IFS=$'\t' read -r ts kind detail; do
                echo "  [$(format_time "$ts")] $kind: $detail"
            done
        fi
        echo ""
    fi

    if [ "$show_cost" -eq 1 ]; then
        echo -e "${BOLD}Token usage:${RESET}"
        local cost_json
        cost_json=$(jq -s --argjson cutoff "$cutoff_ms" '
            reduce (.[] | select(.type=="message" and .message.role=="assistant") | select((.message.timestamp // 0) >= $cutoff)) as $m
              ({input:0, output:0, cacheRead:0, cacheWrite:0, totalTokens:0, costInput:0, costOutput:0, costCacheRead:0, costCacheWrite:0, costTotal:0};
                .input += ($m.message.usage.input // 0)
                | .output += ($m.message.usage.output // 0)
                | .cacheRead += ($m.message.usage.cacheRead // 0)
                | .cacheWrite += ($m.message.usage.cacheWrite // 0)
                | .totalTokens += ($m.message.usage.totalTokens // 0)
                | .costInput += ($m.message.usage.cost.input // 0)
                | .costOutput += ($m.message.usage.cost.output // 0)
                | .costCacheRead += ($m.message.usage.cost.cacheRead // 0)
                | .costCacheWrite += ($m.message.usage.cost.cacheWrite // 0)
                | .costTotal += ($m.message.usage.cost.total // 0)
              )' "$session_file")

        local total_tokens
        local input_tokens
        local output_tokens
        local cache_read
        local cache_write
        local cost_total
        total_tokens=$(echo "$cost_json" | jq -r '.totalTokens // 0')
        input_tokens=$(echo "$cost_json" | jq -r '.input // 0')
        output_tokens=$(echo "$cost_json" | jq -r '.output // 0')
        cache_read=$(echo "$cost_json" | jq -r '.cacheRead // 0')
        cache_write=$(echo "$cost_json" | jq -r '.cacheWrite // 0')
        cost_total=$(echo "$cost_json" | jq -r '.costTotal // 0')

        echo "  Total tokens: $total_tokens"
        echo "  Input: $input_tokens | Output: $output_tokens"
        echo "  Cache read: $cache_read | Cache write: $cache_write"
        printf "  Cost total: $%.4f\n" "$cost_total"
        echo ""
    fi

    if [ "$follow" -eq 1 ]; then
        echo -e "${BOLD}Following:${RESET} $session_file"
        echo -e "${DIM}(Ctrl+C to stop)${RESET}"
        tail -f "$session_file" | while read -r line; do
            local role
            local ts_ms
            local text
            role=$(echo "$line" | jq -r 'select(.type=="message") | .message.role // empty' 2>/dev/null)
            if [ -z "$role" ]; then
                continue
            fi
            ts_ms=$(echo "$line" | jq -r '.message.timestamp // 0' 2>/dev/null)
            if [ "$ts_ms" -lt "$cutoff_ms" ]; then
                continue
            fi
            text=$(echo "$line" | jq -r '
                def text_of:
                  if (.message.content | type) == "string" then .message.content
                  else ([.message.content[]? | select(.type=="text") | .text] | join(" ")) end;
                text_of // ""' 2>/dev/null)
            if [ -z "$text" ]; then
                text="(no text)"
            fi
            echo "  [$(format_time "$ts_ms")] $role: $text"
        done
    fi
}

pi_subscribe() {
    local input="$1"
    shift

    local messages_count=1
    local show_full=0
    local wait_next=1
    local show_initial=0
    local timeout_seconds=-1
    local last_or_next=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --messages|-m)
                if [ -z "${2:-}" ]; then
                    echo "Missing value for --messages"
                    exit 1
                fi
                messages_count="$2"
                shift 2
                ;;
            --next|-n|--wait)
                wait_next=1
                show_initial=0
                shift
                ;;
            --last|-l)
                wait_next=0
                show_initial=1
                shift
                ;;
            --last-or-next)
                last_or_next=1
                wait_next=1
                show_initial=0
                shift
                ;;
            --timeout|-t)
                if [ -z "${2:-}" ]; then
                    echo "Missing value for --timeout"
                    exit 1
                fi
                timeout_seconds="$2"
                shift 2
                ;;
            --full)
                show_full=1
                shift
                ;;
            *)
                echo "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    if [ -z "$input" ]; then
        echo "Usage: dev pi-subscribe <session> [options]"
        echo ""
        echo "Subscribe to final agent messages (agent_end events)."
        echo ""
        echo "Options:"
        echo "  --messages, -m <n>  Show last n entries before waiting"
        echo "  --next, -n          Wait for the next entry, then exit (default)"
        echo "  --wait              Alias for --next"
        echo "  --last, -l          Show the last completion and exit"
        echo "  --last-or-next      Show last completion if it exists, otherwise wait"
        echo "  --timeout, -t <s>   Exit after N seconds if no completion"
        echo "  --full              Show full message text"
        exit 1
    fi

    IFS='/' read -ra parts <<< "$input"
    local repo="${parts[0]}"
    local worktree="${parts[1]:-main}"
    local repo_dir="$PROJECTS_DIR/$repo"
    local target_dir=""
    local sub=""

    if [ -d "$repo_dir/.bare" ]; then
        target_dir="$repo_dir/$worktree"
        sub="${parts[2]:-}"
    else
        target_dir="$repo_dir"
        sub="${parts[1]:-}"
    fi

    if [ ! -d "$target_dir" ]; then
        echo "Directory not found: $target_dir"
        exit 1
    fi

    local status_file=""
    local queue_file=""

    if [[ "$sub" == kw-* ]]; then
        local kw_name
        kw_name="${sub#kw-}"
        status_file=$(kw_meta_get "$repo" "$kw_name" "statusFile")
        if [ -z "$status_file" ]; then
            status_file=$(kw_status_file "$repo" "$kw_name")
        fi
        queue_file=$(kw_meta_get "$repo" "$kw_name" "queueFile")
        if [ -z "$queue_file" ]; then
            queue_file=$(kw_queue_file "$repo" "$kw_name")
        fi
    else
        if [ -n "$sub" ]; then
            local sub_dir="$target_dir/$sub"
            local dot_sub_dir="$target_dir/.${sub}"
            local chosen=""

            for candidate in "$sub_dir" "$dot_sub_dir"; do
                if [ -d "$candidate" ]; then
                    local safe_candidate
                    safe_candidate=$(echo "$candidate" | tr '[:upper:]' '[:lower:]' | sed 's|/|-|g' | sed 's|^-||')
                    local session_candidate="$HOME/.pi/agent/sessions/--${safe_candidate}--"
                    if [ -d "$session_candidate" ]; then
                        chosen="$candidate"
                        break
                    fi
                fi
            done

            if [ -n "$chosen" ]; then
                target_dir="$chosen"
            fi
        fi

        local safe_path
        safe_path=$(echo "$target_dir" | tr '[:upper:]' '[:lower:]' | sed 's|/|-|g' | sed 's|^-||')
        status_file="$HOME/.pi/status/${safe_path}.jsonl"
        queue_file="$HOME/.pi/queues/${safe_path}.jsonl"

        if [ ! -f "$status_file" ]; then
            safe_path=$(echo "$target_dir" | sed 's|/|-|g' | sed 's|^-||')
            status_file="$HOME/.pi/status/${safe_path}.jsonl"
            queue_file="$HOME/.pi/queues/${safe_path}.jsonl"
        fi
    fi

    if [ ! -f "$status_file" ] && [ "$wait_next" -eq 1 ]; then
        local waited=0
        local timeout=10
        while [ ! -f "$status_file" ] && [ "$waited" -lt "$timeout" ]; do
            sleep 1
            waited=$((waited + 1))
        done
    fi

    if [ ! -f "$status_file" ]; then
        echo "No status file found for: $input"
        echo "Expected: $status_file"
        echo ""
        echo "Make sure the pi-subscribe extension is loaded."
        exit 1
    fi

    if [ "$wait_next" -eq 1 ] && [ "$timeout_seconds" -lt 0 ]; then
        local last_status
        last_status=$(tail -n 1 "$status_file" 2>/dev/null | jq -r '.status // empty' 2>/dev/null)
        if [ "$last_status" = "working" ]; then
            timeout_seconds=900
        else
            timeout_seconds=30
        fi
    fi

    format_time() {
        local ts_ms="$1"
        if [ -z "$ts_ms" ] || [ "$ts_ms" = "null" ]; then
            echo "unknown"
            return
        fi
        if ! [[ "$ts_ms" =~ ^[0-9]+$ ]]; then
            echo "unknown"
            return
        fi
        local ts_s=$((ts_ms / 1000))
        date -r "$ts_s" "+%Y-%m-%d %H:%M:%S"
    }

    render_line() {
        local line="$1"
        local ts_ms
        local msg
        local status
        local stop_reason
        local error_msg
        ts_ms=$(echo "$line" | jq -r '.timestamp // 0' 2>/dev/null)
        msg=$(echo "$line" | jq -r '.message // ""' 2>/dev/null)
        status=$(echo "$line" | jq -r '.status // "done"' 2>/dev/null)
        stop_reason=$(echo "$line" | jq -r '.stopReason // empty' 2>/dev/null)
        error_msg=$(echo "$line" | jq -r '.errorMessage // empty' 2>/dev/null)

        if [ -z "$msg" ]; then
            msg="(no text)"
        fi

        if [ "$show_full" -ne 1 ]; then
            msg=$(echo "$msg" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g')
            msg=$(echo "$msg" | cut -c1-240)
        fi

        local status_label="$status"
        if [ -n "$stop_reason" ]; then
            status_label="$status ($stop_reason)"
        fi
        if [ -n "$error_msg" ]; then
            status_label="$status error: $error_msg"
        fi

        echo "  [$(format_time "$ts_ms")] $status_label: $msg"
    }

    if [ "$last_or_next" -eq 1 ]; then
        local last_line
        last_line=$(tail -n 1 "$status_file" 2>/dev/null || true)
        if [ -n "$last_line" ]; then
            render_line "$last_line"
            return
        fi
    fi

    if [ "$show_initial" -eq 1 ]; then
        local lines
        lines=$(tail -n "$messages_count" "$status_file" 2>/dev/null || true)

        if [ -n "$lines" ]; then
            while IFS= read -r line; do
                [ -z "$line" ] && continue
                render_line "$line"
            done <<< "$lines"
        else
            echo "(no status entries)"
        fi
    fi

    if [ "$wait_next" -eq 1 ]; then
        local start_lines
        local current_lines
        local start_time
        start_lines=$(wc -l < "$status_file" | tr -d ' ')
        start_lines=${start_lines:-0}
        start_time=$(date +%s)

        while true; do
            current_lines=$(wc -l < "$status_file" | tr -d ' ')
            current_lines=${current_lines:-0}
            if [ "$current_lines" -lt "$start_lines" ]; then
                start_lines="$current_lines"
            elif [ "$current_lines" -gt "$start_lines" ]; then
                local last_line
                last_line=$(tail -n 1 "$status_file")
                local last_status
                last_status=$(echo "$last_line" | jq -r '.status // empty' 2>/dev/null)
                if [ "$last_status" = "done" ] || [ "$last_status" = "error" ]; then
                    render_line "$last_line"
                    break
                fi
                start_lines="$current_lines"
            fi
            if [ "$timeout_seconds" -gt 0 ]; then
                local now
                now=$(date +%s)
                if [ $((now - start_time)) -ge "$timeout_seconds" ]; then
                    echo "(timed out waiting for completion)"
                    return
                fi
            fi
            sleep 1
        done
        return
    fi
}

queue_status() {
    local input="$1"
    shift

    local show_messages=0
    local show_dead=0
    local clear_queue=0
    local clear_dead=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --messages|-m)
                show_messages=1
                shift
                ;;
            --dead-letter|-d)
                show_dead=1
                shift
                ;;
            --clear|-c)
                clear_queue=1
                shift
                ;;
            --clear-dead|--clear-dead-letter|-x)
                clear_dead=1
                shift
                ;;
            --clear-all|-a)
                clear_queue=1
                clear_dead=1
                shift
                ;;
            *)
                echo "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    if [ -z "$input" ]; then
        echo "Usage: dev queue-status <session> [options]"
        echo ""
        echo "Show queue status for a pi agent."
        echo ""
        echo "Options:"
        echo "  --messages, -m         Show pending queue messages"
        echo "  --dead-letter, -d      Show dead-letter entries"
        echo "  --clear, -c            Clear pending queue messages"
        echo "  --clear-dead, -x       Clear dead-letter entries"
        echo "  --clear-all, -a        Clear queue and dead-letter"
        exit 1
    fi

    IFS='/' read -ra parts <<< "$input"
    local repo="${parts[0]}"
    local worktree="${parts[1]:-main}"
    local repo_dir="$PROJECTS_DIR/$repo"
    local target_dir=""
    local sub=""

    if [ -d "$repo_dir/.bare" ]; then
        target_dir="$repo_dir/$worktree"
        sub="${parts[2]:-}"
    else
        target_dir="$repo_dir"
        sub="${parts[1]:-}"
    fi

    if [ ! -d "$target_dir" ]; then
        echo "Directory not found: $target_dir"
        exit 1
    fi

    local queue_file=""
    local dead_file=""

    if [[ "$sub" == kw-* ]]; then
        local kw_name
        kw_name="${sub#kw-}"
        queue_file=$(kw_meta_get "$repo" "$kw_name" "queueFile")
        if [ -z "$queue_file" ]; then
            queue_file=$(kw_queue_file "$repo" "$kw_name")
        fi
        dead_file="$queue_file.dead-letter"
    else
        if [ -n "$sub" ]; then
            local sub_dir="$target_dir/$sub"
            local dot_sub_dir="$target_dir/.${sub}"
            local chosen=""

            for candidate in "$sub_dir" "$dot_sub_dir"; do
                if [ -d "$candidate" ]; then
                    local safe_candidate
                    safe_candidate=$(echo "$candidate" | tr '[:upper:]' '[:lower:]' | sed 's|/|-|g' | sed 's|^-||')
                    local session_candidate="$HOME/.pi/agent/sessions/--${safe_candidate}--"
                    if [ -d "$session_candidate" ]; then
                        chosen="$candidate"
                        break
                    fi
                fi
            done

            if [ -n "$chosen" ]; then
                target_dir="$chosen"
            fi
        fi

        local safe_path
        safe_path=$(echo "$target_dir" | tr '[:upper:]' '[:lower:]' | sed 's|/|-|g' | sed 's|^-||')
        queue_file="$HOME/.pi/queues/${safe_path}.jsonl"
        dead_file="$queue_file.dead-letter"
    fi

    if [ "$clear_queue" -eq 1 ]; then
        : > "$queue_file"
        echo "Cleared queue: $queue_file"
    fi
    if [ "$clear_dead" -eq 1 ]; then
        : > "$dead_file"
        echo "Cleared dead-letter: $dead_file"
    fi

    local queue_size=0
    local dead_size=0

    if [ -f "$queue_file" ]; then
        queue_size=$(wc -c < "$queue_file" | tr -d ' ')
    fi
    if [ -f "$dead_file" ]; then
        dead_size=$(wc -c < "$dead_file" | tr -d ' ')
    fi

    echo -e "${BOLD}Queue:${RESET} $input"
    echo -e "${DIM}File: $queue_file${RESET}"
    echo -e "${DIM}Size: ${queue_size} bytes${RESET}"

    if [ "$show_messages" -eq 1 ]; then
        if [ ! -s "$queue_file" ]; then
            echo "  (no pending messages)"
        else
            echo -e "${BOLD}Pending messages:${RESET}"
            cat "$queue_file"
        fi
    fi

    echo ""
    echo -e "${DIM}Dead-letter: $dead_file${RESET}"
    echo -e "${DIM}Dead-letter size: ${dead_size} bytes${RESET}"
    if [ "$show_dead" -eq 1 ]; then
        if [ ! -s "$dead_file" ]; then
            echo "  (no dead-letter entries)"
        else
            echo -e "${BOLD}Dead-letter entries:${RESET}"
            cat "$dead_file"
        fi
    fi
}

hub_session() {
    local sub="$1"
    local session_name="hub"
    local target_dir="$PROJECTS_DIR"

    if [ -n "$sub" ]; then
        session_name="hub${SEP}${sub}"
    fi

    cd "$target_dir"
    local display_name=$(to_display_name "$session_name")
    echo -e "Directory: ${CYAN}$target_dir${RESET}"
    echo -e "Session: ${GREEN}$display_name${RESET}"

    local auto_command=()
    if [ -n "$sub" ]; then
        case "$sub" in
            pi)
                auto_command=(pi)
                ;;
            claude)
                auto_command=(claude --dangerously-skip-permissions)
                ;;
        esac
    fi

    local backend
    backend=$(session_backend "$session_name")

    if [ "$backend" = "tmux" ]; then
        # If the agent process has exited (pane is at a shell prompt), restart it
        if [ ${#auto_command[@]} -gt 0 ]; then
            local pane_cmd
            pane_cmd=$(tmux display-message -t "$session_name" -p '#{pane_current_command}' 2>/dev/null || true)
            local agent_name="${auto_command[0]}"
            if [[ "$pane_cmd" == "zsh" || "$pane_cmd" == "bash" || "$pane_cmd" == "sh" || "$pane_cmd" == "fish" ]]; then
                echo -e "${YELLOW}Agent ($agent_name) not running — restarting...${RESET}"
                local cmd_line="${auto_command[*]}"
                tmux send-keys -t "$session_name" "$cmd_line" C-m
            fi
        fi
        tmux attach -t "$session_name"
        return
    fi

    # Create new session detached (safe for non-interactive callers)
    tmux new-session -d -s "$session_name" -c "$target_dir"
    if [ ${#auto_command[@]} -gt 0 ]; then
        local cmd_line
        cmd_line="${auto_command[*]}"
        tmux send-keys -t "$session_name" "$cmd_line" C-m
    fi
    echo -e "${GREEN}Started:${RESET} $display_name (detached)"
    echo -e "Attach with: ${CYAN}dev $display_name${RESET}"
}

# Main
case "${1:-}" in
    "")
        list_projects 0
        ;;
    hub|hub/*)
        # Extract sub-session if provided (hub/claude -> claude)
        if [[ "$1" == "hub/"* ]]; then
            sub="${1#hub/}"
            hub_session "$sub"
        else
            hub_session ""
        fi
        ;;
    "new")
        new_project "$2" "$3"
        ;;
    "init")
        init_project "$2"
        ;;
    "wt"|"worktree")
        add_worktree "$2" "$3" "$4"
        ;;
    "task")
        case "${2:-}" in
            "slice")
                case "${3:-}" in
                    "new")
                        task_slice_new "$4" "$5" "$6"
                        ;;
                    "start")
                        task_slice_start "$4" "$5" "$6"
                        ;;
                    "status")
                        task_slice_status "$4" "$5" "$6"
                        ;;
                    "validate")
                        task_slice_validate "$4" "$5" "$6"
                        ;;
                    "request-revision")
                        task_slice_request_revision "$4" "$5" "$6"
                        ;;
                    "reopen")
                        task_slice_reopen "$4" "$5" "$6"
                        ;;
                    "approve-commit")
                        task_slice_approve_commit "$4" "$5" "$6"
                        ;;
                    "committed")
                        task_slice_committed "$4" "$5" "$6" "$7"
                        ;;
                    *)
                        echo "Usage:"
                        echo "  dev task slice new <repo> <slug> <slice-id>"
                        echo "  dev task slice start <repo> <slug> <slice-id>"
                        echo "  dev task slice status <repo> <slug> <slice-id>"
                        echo "  dev task slice validate <repo> <slug> <slice-id>"
                        echo "  dev task slice request-revision <repo> <slug> <slice-id>"
                        echo "  dev task slice reopen <repo> <slug> <slice-id>"
                        echo "  dev task slice approve-commit <repo> <slug> <slice-id>"
                        echo "  dev task slice committed <repo> <slug> <slice-id> <commit>"
                        exit 1
                        ;;
                esac
                ;;
            "new")
                task_new "$3" "$4"
                ;;
            "status")
                task_status "$3" "$4"
                ;;
            "sessions")
                task_sessions "$3" "$4"
                ;;
            "open")
                task_role_open "$3" "$4" "${5:-plan-owner-codex}"
                ;;
            "open-current")
                task_open_current "$3" "$4" "${5:-}"
                ;;
            "open-slice")
                task_open_slice "$3" "$4" "$5" "${6:-implementer-codex}"
                ;;
            "lock-plan")
                task_lock_plan "$3" "$4"
                ;;
            "validate")
                task_validate_phase "$3" "$4" "${5:-plan}"
                ;;
            "signoff")
                task_signoff "$3" "$4" "$5" "$6" "$7" "${8:-}"
                ;;
            "send")
                task_send "$3" "$4" "$5" "${@:6}"
                ;;
            "poll")
                task_poll "$3" "$4"
                ;;
            "nudge")
                task_nudge "$3" "$4" "$5" "${@:6}"
                ;;
            "review")
                task_review "$3" "$4"
                ;;
            "verify")
                task_verify "$3" "$4"
                ;;
            "start-impl")
                task_start_impl "$3" "$4" "$5"
                ;;
            "ready-merge")
                task_mark_ready_merge "$3" "$4"
                ;;
            "merged")
                task_mark_merged "$3" "$4" "$5"
                ;;
            "close")
                task_close "$3" "$4" "$5"
                ;;
            *)
                echo "Usage:"
                echo "  dev task new <repo> <slug>"
                echo "  dev task status <repo> <slug>"
                echo "  dev task sessions <repo> <slug>"
                echo "  dev task open <repo> <slug> [role]"
                echo "  dev task open-current <repo> <slug> [role]"
                echo "  dev task open-slice <repo> <slug> <slice-id> [role]"
                echo "  dev task slice new <repo> <slug> <slice-id>"
                echo "  dev task slice start <repo> <slug> <slice-id>"
                echo "  dev task slice status <repo> <slug> <slice-id>"
                echo "  dev task slice validate <repo> <slug> <slice-id>"
                echo "  dev task slice request-revision <repo> <slug> <slice-id>"
                echo "  dev task slice reopen <repo> <slug> <slice-id>"
                echo "  dev task slice approve-commit <repo> <slug> <slice-id>"
                echo "  dev task slice committed <repo> <slug> <slice-id> <commit>"
                echo "  dev task lock-plan <repo> <slug>"
                echo "  dev task validate <repo> <slug> [plan|implementation]"
                echo "  dev task signoff <repo> <slug> <plan|implementation> <role> <approved|blocked|revoked> [note]"
                echo "  dev task send <repo> <slug> <role> <message>"
                echo "  dev task poll <repo> <slug>"
                echo "  dev task nudge <repo> <slug> <role> <message>"
                echo "  dev task review <repo> <slug>"
                echo "  dev task verify <repo> <slug>"
                echo "  dev task start-impl <repo> <slug> [worktree]"
                echo "  dev task ready-merge <repo> <slug>"
                echo "  dev task merged <repo> <slug> [merge-ref]"
                echo "  dev task close <repo> <slug> [--cleanup]"
                echo ""
                echo "Roles:"
                echo "  plan-owner-codex"
                echo "  plan-review-codex"
                echo "  plan-critic-claude"
                echo "  implementer-codex"
                echo "  implementation-review-codex"
                echo "  implementation-critic-claude"
                exit 1
                ;;
        esac
        ;;
    "project")
        case "${2:-}" in
            "tasks")
                project_tasks_dashboard "$3"
                ;;
            "review")
                project_review "$3"
                ;;
            "poll")
                project_poll "$3"
                ;;
            "sessions")
                project_sessions "$3"
                ;;
            *)
                echo "Usage:"
                echo "  dev project tasks <repo>"
                echo "  dev project review <repo>"
                echo "  dev project poll <repo>"
                echo "  dev project sessions <repo>"
                exit 1
                ;;
        esac
        ;;
    "kill")
        if [ -z "$2" ]; then
            echo "Usage: dev kill <session-name>"
            exit 1
        fi
        kill_session "$2"
        ;;
    "cleanup")
        cleanup_worktree "$2" "${@:3}"
        ;;
    "send")
        send_keys "$2" "${@:3}"
        ;;
    "send-pi")
        send_pi "$2" "${@:3}"
        ;;
    "pi-gh-assign")
        pi_gh_assign "${@:2}"
        ;;
    "kw")
        kw_session "$2" "$3" "${@:4}"
        ;;
    "kw-list")
        kw_list "$2"
        ;;
    "kw-tags")
        kw_tag "$2" "${@:3}"
        ;;
    "kw-note")
        kw_note "$2" "${@:3}"
        ;;
    "pi-status")
        pi_status "${@:2}"
        ;;
    "pi-subscribe")
        pi_subscribe "${@:2}"
        ;;
    "queue-status")
        queue_status "${@:2}"
        ;;
    "requirements")
        requirements "$2" "${@:3}"
        ;;
    "review")
        review_session "$2"
        ;;
    "review-loop")
        review_loop
        ;;
    "reboot")
        reboot_sessions "${@:2}"
        ;;
    "ls"|"list")
        if [ "${2:-}" = "--full" ] || [ "${2:-}" = "--tree" ]; then
            list_projects 1
        else
            list_projects 0
        fi
        ;;
    "help"|"-h"|"--help")
        echo "dev - Project session manager (with git worktree support)"
        echo ""
        echo "Commands:"
        echo "  dev                           List active sessions"
        echo "  dev ls [--full]              List active sessions (or full project tree)"
        echo "  dev hub                       Attach to hub session at projects root"
