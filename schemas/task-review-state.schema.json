{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cashew.local/schemas/task-review-state.schema.json",
  "title": "Cashew Task Review State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reviewerRole",
    "decision",
    "blockingFindings",
    "nonBlockingFindings",
    "summary",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "reviewerRole": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": ["pending", "approved", "blocked"]
    },
    "blockingFindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "nonBlockingFindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "summary": {
      "type": "string"
    },
    "updatedAt": {
      "type": ["string", "null"]
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "claim", "evidence"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
